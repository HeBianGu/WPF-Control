<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:componentmodel="clr-namespace:System.ComponentModel;assembly=WindowsBase"
    xmlns:local="clr-namespace:H.Modules.Globalization">

    <DataTemplate DataType="{x:Type local:GlobalizationViewPresenter}">
        <ListBox
            Cattach.ItemHeight="Auto"
            BorderThickness="0"
            ItemsSource="{Binding Source={x:Static local:GlobalizationOptions.Instance}, Path=SupportedCultInfos}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectedItem="{Binding Source={x:Static local:GlobalizationOptions.Instance}, Path=CultureInfo, Mode=TwoWay}">

            <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="Margin" Value="8,6" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static BrushKeys.BorderBrush}}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                <Border
                                    x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                    <ContentPresenter Margin="12,10" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                                        <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: main info -->
                        <StackPanel Grid.Column="0">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="{Binding NativeName, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />

                            <TextBlock
                                Margin="0,4,0,0"
                                Opacity="0.85"
                                TextTrimming="CharacterEllipsis">
                                <Run Text="{Binding EnglishName, Mode=OneWay}" />
                                <Run Text="  ˇ¤  " />
                                <Run Text="{Binding DisplayName, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>

                        <!-- Right: culture code badge -->
                        <Border
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                            CornerRadius="10"
                            Padding="10,4"
                            Margin="10,0,0,0">
                            <TextBlock
                                FontFamily="Consolas"
                                FontWeight="SemiBold"
                                Text="{Binding Name, Mode=OneWay}" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DataTemplate>
</ResourceDictionary>