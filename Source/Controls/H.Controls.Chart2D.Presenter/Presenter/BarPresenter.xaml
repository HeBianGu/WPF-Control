<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.Controls.Chart2D.Presenter.Presenter">
    <DataTemplate DataType="{x:Type local:BarPresenter}">
        <DesignBorder>
            <Chart
                MinWidth="200"
                Background="{x:Null}"
                Style="{DynamicResource {x:Static Chart.BarKey}}"
                UseDrawOnce="False"
                UseLegend="{Binding UseLegend}"
                UseRefreshButton="False"
                Visibility="{Binding IsVisible, Converter={x:Static Converter.GetTrueToVisible}}"
                xAxis="{Binding xAxis}"
                xDisplay="{Binding xDisplay}"
                yAxis="{Binding yAxis}">
                <Series
                    DisplayName="{Binding Name}"
                    Style="{DynamicResource {x:Static Series.BarKey}}"
                    yDatas="{Binding Data}">
                    <MarkPosition
                        Foreground="{DynamicResource {x:Static BrushKeys.Background}}"
                        MarkForeground="{DynamicResource {x:Static BrushKeys.Foreground}}"
                        MarkValueType="Last"
                        Style="{DynamicResource {x:Static MarkPosition.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseLastMarkPositon, Converter={x:Static Converter.GetTrueToVisible}}" />
                    <MarkPosition
                        Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                        MarkValueType="Max"
                        Style="{DynamicResource {x:Static MarkPosition.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMaxMarkPositon, Converter={x:Static Converter.GetTrueToVisible}}" />

                    <MarkPosition
                        Foreground="{DynamicResource {x:Static BrushKeys.Green}}"
                        MarkValueType="Min"
                        Style="{DynamicResource {x:Static MarkPosition.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMinMarkPositon, Converter={x:Static Converter.GetTrueToVisible}}" />
                    <MarkLine
                        Data="{Binding Data}"
                        Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                        MarkLineType="Min"
                        Style="{DynamicResource {x:Static MarkLine.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMaxMarkLine, Converter={x:Static Converter.GetTrueToVisible}}"
                        Value="{Binding MaxValue}" />

                    <MarkLine
                        Data="{Binding Data}"
                        Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                        MarkLineType="Max"
                        Style="{DynamicResource {x:Static MarkLine.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMinMarkLine, Converter={x:Static Converter.GetTrueToVisible}}"
                        Value="{Binding MinValue}" />

                    <MarkLine
                        Data="{Binding Data}"
                        MarkLineType="Average"
                        Style="{DynamicResource {x:Static MarkLine.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseAverageMarkLine, Converter={x:Static Converter.GetTrueToVisible}}" />
                </Series>
            </Chart>
        </DesignBorder>
    </DataTemplate>
</ResourceDictionary>