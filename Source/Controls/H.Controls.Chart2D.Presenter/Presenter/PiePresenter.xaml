<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.Controls.Chart2D.Presenter.Presenter">
    <DataTemplate DataType="{x:Type local:PiePresenter}">
        <DesignBorder>
            <Chart
                MinWidth="200"
                Background="{x:Null}"
                UseDrawOnce="False"
                UseRefreshButton="False"
                Visibility="{Binding IsVisible, Converter={x:Static Converter.GetTrueToVisible}}">
                <Series>
                    <Pie
                        Data="{Binding Data}"
                        Foreground="{Binding Foreground}"
                        TryFreeze="False"
                        xDisplay="{Binding xDisplay}" />
                </Series>
                <PathLegend />
            </Chart>
        </DesignBorder>
    </DataTemplate>
</ResourceDictionary>