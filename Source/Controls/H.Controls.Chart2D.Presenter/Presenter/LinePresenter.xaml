<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.Controls.Chart2D.Presenter.Presenter">

    <DataTemplate DataType="{x:Type local:LinePresenter}">
        <DesignBorder>
            <Chart
                Background="{x:Null}"
                Style="{DynamicResource {x:Static Chart.CoordKey}}"
                UseDrawOnce="False"
                UseGrid="{Binding UseGrid}"
                UseLegend="{Binding UseLegend}"
                UseRefreshButton="False"
                UsexAxis="{Binding UsexAxis}"
                UseyAxis="{Binding UseyAxis}"
                Visibility="{Binding IsVisible, Converter={x:Static Converter.GetTrueToVisible}}"
                xAxis="{Binding xAxis}"
                xDisplay="{Binding xDisplay}"
                yAxis="{Binding yAxis}">
                <Series DisplayName="{Binding Name}" yDatas="{Binding Data}">
                    <h:Line />
                    <Scatter />
                    <MarkPosition
                        Foreground="{DynamicResource {x:Static BrushKeys.Background}}"
                        MarkForeground="{DynamicResource {x:Static BrushKeys.Foreground}}"
                        MarkValueType="Last"
                        Style="{DynamicResource {x:Static MarkPosition.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseLastMarkPositon, Converter={x:Static Converter.GetTrueToVisible}}" />
                    <MarkPosition
                        Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                        MarkValueType="Max"
                        Style="{DynamicResource {x:Static MarkPosition.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMaxMarkPositon, Converter={x:Static Converter.GetTrueToVisible}}" />

                    <MarkPosition
                        Foreground="{DynamicResource {x:Static BrushKeys.Green}}"
                        MarkValueType="Min"
                        Style="{DynamicResource {x:Static MarkPosition.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMinMarkPositon, Converter={x:Static Converter.GetTrueToVisible}}" />

                    <MarkLine
                        Data="{Binding Data}"
                        Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                        MarkLineType="Max"
                        Style="{DynamicResource {x:Static MarkLine.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMaxMarkLine, Converter={x:Static Converter.GetTrueToVisible}}"
                        Value="{Binding MaxValue}" />

                    <MarkLine
                        Data="{Binding Data}"
                        Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                        MarkLineType="Min"
                        Style="{DynamicResource {x:Static MarkLine.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMinMarkLine, Converter={x:Static Converter.GetTrueToVisible}}"
                        Value="{Binding MinValue}" />

                    <MarkLine
                        Data="{Binding Data}"
                        MarkLineType="Average"
                        Style="{DynamicResource {x:Static MarkLine.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseAverageMarkLine, Converter={x:Static Converter.GetTrueToVisible}}" />
                </Series>
            </Chart>
        </DesignBorder>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:DynimacLinePresenter}">
        <DesignBorder>
            <Chart
                Padding="{Binding Padding}"
                Background="Transparent"
                Style="{DynamicResource {x:Static Chart.CoordScreenKey}}"
                UseGrid="{Binding UseGrid}"
                UseRefreshButton="False"
                UsexAxis="{Binding UsexAxis}"
                UseyAxis="{Binding UseyAxis}"
                xAxis="{Binding xAxis}"
                xDisplay="{Binding xDisplay}"
                yAxis="{Binding yAxis}">
                <Chart.LegendStyle>
                    <Style TargetType="Legend">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </Style>
                </Chart.LegendStyle>
                <Series
                    DisplayName="{Binding Name}"
                    Foreground="{DynamicResource {x:Static BrushKeys.Foreground}}"
                    yDatas="{Binding Data}">
                    <Area
                        AreaBackground="{DynamicResource {x:Static BrushKeys.Foreground}}"
                        Opacity="0.1"
                        Style="{DynamicResource {x:Static Area.SingleKey}}"
                        TryFreeze="False"
                        UseSmooth="False" />
                    <h:Line Style="{DynamicResource {x:Static h:Line.SingleKey}}" TryFreeze="False" />

                    <MarkPosition
                        Foreground="{DynamicResource {x:Static BrushKeys.Background}}"
                        MarkForeground="{DynamicResource {x:Static BrushKeys.Foreground}}"
                        MarkValueType="Last"
                        Style="{DynamicResource {x:Static MarkPosition.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseLastMarkPositon, Converter={x:Static Converter.GetTrueToVisible}}" />
                    <MarkPosition
                        Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                        MarkValueType="Max"
                        Style="{DynamicResource {x:Static MarkPosition.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMaxMarkPositon, Converter={x:Static Converter.GetTrueToVisible}}" />

                    <MarkPosition
                        Foreground="{DynamicResource {x:Static BrushKeys.Green}}"
                        MarkValueType="Min"
                        Style="{DynamicResource {x:Static MarkPosition.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMinMarkPositon, Converter={x:Static Converter.GetTrueToVisible}}" />

                    <MarkLine
                        Data="{Binding Data}"
                        Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                        MarkLineType="Max"
                        Style="{DynamicResource {x:Static MarkLine.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMaxMarkLine, Converter={x:Static Converter.GetTrueToVisible}}"
                        Value="{Binding MaxValue}" />

                    <MarkLine
                        Data="{Binding Data}"
                        Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                        MarkLineType="Min"
                        Style="{DynamicResource {x:Static MarkLine.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseMinMarkLine, Converter={x:Static Converter.GetTrueToVisible}}"
                        Value="{Binding MinValue}" />

                    <MarkLine
                        Data="{Binding Data}"
                        MarkLineType="Average"
                        Style="{DynamicResource {x:Static MarkLine.SingleKey}}"
                        TryFreeze="False"
                        Visibility="{Binding UseAverageMarkLine, Converter={x:Static Converter.GetTrueToVisible}}" />

                </Series>
            </Chart>
        </DesignBorder>
    </DataTemplate>
</ResourceDictionary>