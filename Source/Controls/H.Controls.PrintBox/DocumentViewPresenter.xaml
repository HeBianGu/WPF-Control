<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.Controls.PrintBox"
    xmlns:system="clr-namespace:System;assembly=netstandard">
    <DataTemplate DataType="{x:Type local:DocumentViewPresenter}">
        <Grid>
            <DocumentViewer
                x:Name="dv"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                Background="Transparent"
                Document="{Binding Document}">
                <DocumentViewer.Style>
                    <Style TargetType="{x:Type DocumentViewer}">
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static h:BrushKeys.Foreground}}" />
                        <Setter Property="Background" Value="{DynamicResource {x:Static h:BrushKeys.Background}}" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DocumentViewer}">
                                    <Border
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Focusable="False">
                                        <Grid KeyboardNavigation.TabNavigation="Local">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <ScrollViewer
                                                x:Name="PART_ContentHost"
                                                Grid.Row="1"
                                                CanContentScroll="true"
                                                HorizontalScrollBarVisibility="Auto"
                                                IsTabStop="true" />

                                            <ContentControl
                                                x:Name="PART_FindToolBarHost"
                                                Grid.Row="2"
                                                Visibility="Collapsed" />
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DocumentViewer.Style>
            </DocumentViewer>
            <Border
                Margin="5"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="2"
                DockPanel.Dock="Top">
                <Border.Background>
                    <SolidColorBrush Opacity="0.2" Color="Black" />
                </Border.Background>
                <StackPanel>
                    <FontIconButton
                        Command="ApplicationCommands.Print"
                        CommandTarget="{Binding ElementName=dv}"
                        Content="{x:Static FontIcons.Print}"
                        ToolTip="打印" />
                    <FontIconButton
                        Command="NavigationCommands.IncreaseZoom"
                        CommandTarget="{Binding ElementName=dv}"
                        Content="{x:Static FontIcons.ZoomIn}"
                        ToolTip="放大" />
                    <FontIconButton
                        Command="NavigationCommands.DecreaseZoom"
                        CommandTarget="{Binding ElementName=dv}"
                        Content="{x:Static FontIcons.ZoomOut}"
                        ToolTip="缩小" />
                    <!--<Separator />-->
                    <FontIconButton
                        Command="NavigationCommands.Zoom"
                        CommandParameter="100.0"
                        CommandTarget="{Binding ElementName=dv}"
                        Content="{x:Static FontIcons.FitPage}"
                        ToolTip="实际尺寸" />
                    <FontIconButton
                        Command="DocumentViewer.FitToWidthCommand"
                        CommandTarget="{Binding ElementName=dv}"
                        Content="{x:Static FontIcons.FullScreen}"
                        ToolTip="宽度自适应" />
                    <FontIconButton
                        Command="DocumentViewer.FitToMaxPagesAcrossCommand"
                        CommandParameter="1"
                        CommandTarget="{Binding ElementName=dv}"
                        Content="{x:Static FontIcons.Page}"
                        ToolTip="整页" />
                    <FontIconButton
                        Command="DocumentViewer.FitToMaxPagesAcrossCommand"
                        CommandParameter="2"
                        CommandTarget="{Binding ElementName=dv}"
                        Content="{x:Static FontIcons.TwoPage}"
                        ToolTip="两页" />
                </StackPanel>

            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>