<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters.PageTabs"
    xmlns:m="clr-namespace:H.App.AIDI.Model">
    <DataTemplate DataType="{x:Type local:InputShowModePageTabPresenter}">
        <DockPanel>
            <TextBlock Text="显示类型：" VerticalAlignment="Center" Margin="5,0" />
            <CheckBox Content="标签名称" IsChecked="{Binding ShowLabelName}"/>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>