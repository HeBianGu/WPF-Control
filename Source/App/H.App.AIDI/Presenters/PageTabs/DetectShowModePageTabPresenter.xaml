<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters.PageTabs"
    xmlns:m="clr-namespace:H.App.AIDI.Model">
    <DataTemplate DataType="{x:Type local:DetectShowModePageTabPresenter}">
        <DockPanel LastChildFill="False">
            <TextBlock
                Margin="5,0"
                VerticalAlignment="Center"
                Text="显示类型：" />
            <CheckBox
                Margin="5,0"
                Content="缺陷标注"
                IsChecked="{Binding ShowLabelName}" />
            <CheckBox
                Margin="5,0"
                Content="不学习区域"
                IsChecked="{Binding ShowLabelName}" />
            <CheckBox
                Margin="5,0"
                Content="测试结果"
                IsChecked="{Binding ShowLabelName}" />
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>