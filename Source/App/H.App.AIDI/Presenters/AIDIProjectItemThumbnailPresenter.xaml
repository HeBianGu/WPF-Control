<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters">
    <DataTemplate DataType="{x:Type local:AIDIProjectItemThumbnailPresenter}">
        <DockPanel>
            <TextBlock
                Margin="5"
                HorizontalAlignment="Center"
                DockPanel.Dock="Bottom"
                Text="{Binding ProjectItem.Title}" />
            <Border
                Width="200"
                Height="130"
                Background="{DynamicResource {x:Static BrushKeys.Dark0_1}}"
                Style="{DynamicResource {x:Static BorderKeys.Background}}">
                <Image Source="{Binding ProjectItem.ThumbnialBase64Image, Converter={GetImageSourceFromBase64Converter}}" />
            </Border>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>