<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters">
    <DataTemplate DataType="{x:Type local:TrainManagerTabPresenter}">
        <Border>
            <DockPanel>
                <Border CornerRadius="0" DockPanel.Dock="Top">
                    <UniformGrid DockPanel.Dock="Top" Rows="1">
                        <Button Margin="5" Content="训练" Command="{Binding ModulePresenter.TrainingCommand}"/>
                        <Button Margin="5" Content="推理" Command="{Binding ModulePresenter.InferenceCommand}" />
                    </UniformGrid>
                </Border>
                <Separator DockPanel.Dock="Top" Style="{DynamicResource {x:Static SeparatorKeys.Default}}" />
                <Button
                    Margin="5"
                    Command="{Binding ShowTrainingAssistantCommand}"
                    Content="模型训练助手"
                    DockPanel.Dock="Top" />
                <DockPanel DockPanel.Dock="Top">
                    <FontIconButton
                        Command="{ShowNotImplementedCommand}"
                        Content="{x:Static FontIcons.Globe}"
                        DockPanel.Dock="Right"
                        ToolTip="官方文档" />
                    <FontIconButton
                        Command="{ShowNotImplementedCommand}"
                        Content="{x:Static FontIcons.List}"
                        DockPanel.Dock="Right"
                        ToolTip="从模板文件加载" />
                    <FontIconButton
                        Command="{ShowNotImplementedCommand}"
                        Content="{x:Static FontIcons.Save}"
                        DockPanel.Dock="Right"
                        ToolTip="保存为模板文件" />
                    <TextBlock Margin="5" Foreground="{DynamicResource {x:Static BrushKeys.Accent}}">
                        <Hyperlink>还原参数</Hyperlink>
                    </TextBlock>

                </DockPanel>
                <!--<ContentPresenter Content="{Binding TabFormPresenter}" />-->

                <TabControl Margin="5">
                    <TabItem
                        Width="150"
                        Cattach.CaptionHorizontalAlignment="Center"
                        Header="训练参数">
                        <DockPanel>
                            <CheckBox
                                Margin="5"
                                HorizontalAlignment="Right"
                                Content="显示高级参数"
                                DockPanel.Dock="Top"
                                IsChecked="{Binding UseAdvancedParameters}" />
                            <Form
                                x:Name="form"
                                SelectObject="{Binding YoloConfig}"
                                UseGroup="True"
                                UseGroupNames="基本参数,设备参数,优化器参数,数据增强">
                                <ItemsControl.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="{x:Type GroupItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                                            <Expander
                                                                Margin="0,0,0,1"
                                                                IsExpanded="False"
                                                                Style="{DynamicResource {x:Static ExpanderKeys.ToggleRight}}">
                                                                <Expander.Header>
                                                                    <DockPanel>
                                                                        <TextBlock Margin="0" Text="{Binding Path=Name}" />
                                                                        <!--<TextBlock VerticalAlignment="Center">
                                                    <Run Text="[" /><Run Text="{Binding Path=ItemCount, Mode=OneWay}" /><Run Text="]" />
                                                </TextBlock>-->
                                                                    </DockPanel>
                                                                </Expander.Header>
                                                                <Cattach.CaptionRightTemplate>
                                                                    <ControlTemplate>
                                                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                            <Run Text="{Binding Path=ItemCount, Mode=OneWay}" />
                                                                        </TextBlock>
                                                                    </ControlTemplate>
                                                                </Cattach.CaptionRightTemplate>
                                                                <Expander.Content>
                                                                    <ItemsPresenter />
                                                                </Expander.Content>
                                                            </Expander>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                            </Form>
                        </DockPanel>
                    </TabItem>
                    <TabItem
                        Width="150"
                        Cattach.CaptionHorizontalAlignment="Center"
                        Header="推理参数">
                        <DockPanel>
                            <CheckBox
                                Margin="5"
                                HorizontalAlignment="Right"
                                Content="显示高级参数"
                                DockPanel.Dock="Top"
                                IsChecked="{Binding UseAdvancedParameters}" />
                            <Form SelectObject="{GetStudent}" UseGroup="True" />
                        </DockPanel>
                    </TabItem>
                </TabControl>

            </DockPanel>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding UseAdvancedParameters}" Value="True">
                <Setter TargetName="form" Property="UseGroupNames" Value="{x:Null}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
</ResourceDictionary>