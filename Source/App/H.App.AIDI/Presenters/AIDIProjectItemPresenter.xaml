<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:bs="clr-namespace:H.App.AIDI.Base"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters">
    <DataTemplate DataType="{x:Type local:AIDIProjectItemPresenter}">
        <DataTemplate.Resources>
            <Style
                x:Key="S.Button.GotoPage"
                BasedOn="{StaticResource {x:Static ButtonKeys.Default}}"
                TargetType="Button">
                <Setter Property="Command" Value="{Binding ElementName=dp, Path=DataContext.GotoPageCommand}" />
                <Style.Triggers>
                    <DataTrigger Value="true">
                        <DataTrigger.Binding>
                            <MultiBinding Converter="{x:Static Converter.GetAllEqualsToTrue}" Mode="OneWay">
                                <MultiBinding.Bindings>
                                    <Binding ElementName="dp" Path="DataContext.ProjectItem.SelectedPagePresenter" />
                                    <Binding Path="CommandParameter" RelativeSource="{RelativeSource Mode=Self}" />
                                </MultiBinding.Bindings>
                            </MultiBinding>
                        </DataTrigger.Binding>
                        <Setter Property="Background" Value="{DynamicResource {x:Static BrushKeys.Accent}}" />
                        <Setter Property="Foreground" Value="White" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </DataTemplate.Resources>
        <DockPanel x:Name="dp" Background="{DynamicResource {x:Static BrushKeys.Background}}">
            <StatusBar DockPanel.Dock="Bottom">
                <TextBlock>
                    <Run Text="视图数量：" />
                    <Run Text="10" />
                </TextBlock>
                <TextBlock Margin="5,0">
                    <Run Text="训练集：" />
                    <Run Text="7" />
                </TextBlock>
                <TextBlock>
                    <Run Text="测试集：" />
                    <Run Text="3" />
                </TextBlock>
            </StatusBar>

            <Separator DockPanel.Dock="Bottom" Style="{DynamicResource {x:Static SeparatorKeys.Default}}" />

            <Border
                MinHeight="100"
                DockPanel.Dock="Top"
                Style="{DynamicResource {x:Static BorderKeys.Background}}">
                <DockPanel>
                    <Button
                        Width="120"
                        Command="{ShowProjectsCommand UseAddProject=True}"
                        Style="{DynamicResource {x:Static ButtonKeys.Accent}}">
                        <Button.Content>
                            <DockPanel>
                                <FontIconTextBlock FontSize="12" Text="{x:Static FontIcons.Project}" />
                                <TextBlock
                                    Margin="5,0"
                                    VerticalAlignment="Center"
                                    Text="工程管理" />
                            </DockPanel>
                        </Button.Content>
                    </Button>
                    <SelectProjectComboBox Margin="2,0" />
                    <!--<Button
                        Padding="0"
                        VerticalContentAlignment="Stretch"
                        BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrush}}"
                        BorderThickness="1"
                        CommandParameter="{Binding ProjectItem.InputPagePresenter}"
                        Style="{StaticResource S.Button.GotoPage}">
                        <Button.Content>
                            <DockPanel>
                                <TextBlock
                                    Margin="5,0"
                                    VerticalAlignment="Center"
                                    Text="输入" />
                                <FontIconButton
                                    Width="Auto"
                                    Height="Auto"
                                    Margin="1"
                                    Background="{DynamicResource {x:Static BrushKeys.CaptionBackground}}"
                                    BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrush}}"
                                    BorderThickness="1,0,0,0"
                                    Command="{Binding AddModuleCommand}"
                                    Content="{x:Static FontIcons.CalculatorAddition}"
                                    FontSize="12" />
                            </DockPanel>
                        </Button.Content>
                    </Button>-->
                    <Button
                        Margin="5,0"
                        Padding="10,0"
                        Command="{Binding ProjectItem.SelectedPagePresenter.ApplyCommand}"
                        Content="应用"
                        DockPanel.Dock="Right">
                        <Button.Style>
                            <Style BasedOn="{StaticResource {x:Static ButtonKeys.Accent}}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProjectItem.SelectedPagePresenter.ApplyCommand, FallbackValue={x:Null}, Converter={GetWriteObjectConverter}}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <ScrollViewer
                        Margin="-20,0,0,0"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <TreeLayoutBox
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            ItemsSource="{Binding ModuleTreeNodes, Converter={GetWriteObjectConverter}}"
                            LineWidth="25">
                            <TreeView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource {x:Static TreeLayoutItemKeys.VerticalKey}}" TargetType="{x:Type TreeLayoutItem}">
                                    <Setter Property="IsExpanded" Value="True" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Nodes}">
                                    <ContentPresenter Content="{Binding Model}">
                                        <ContentPresenter.ContentTemplateSelector>
                                            <local:ModuleTreeDataTemplateSelector>
                                                <local:ModuleTreeDataTemplateSelector.InputPagePresenterDataTemplate>
                                                    <DataTemplate>
                                                        <Button
                                                            Padding="0"
                                                            VerticalContentAlignment="Stretch"
                                                            BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrush}}"
                                                            BorderThickness="1"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource S.Button.GotoPage}">
                                                            <Button.Content>
                                                                <DockPanel>
                                                                    <TextBlock
                                                                        Margin="5,0"
                                                                        VerticalAlignment="Center"
                                                                        Text="输入" />
                                                                    <FontIconButton
                                                                        Width="Auto"
                                                                        Height="Auto"
                                                                        Margin="1"
                                                                        Background="{DynamicResource {x:Static BrushKeys.CaptionBackground}}"
                                                                        BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrush}}"
                                                                        BorderThickness="1,0,0,0"
                                                                        Command="{Binding RelativeSource={RelativeSource AncestorType=TreeLayoutBox}, Path=DataContext.AddModuleCommand}"
                                                                        Content="{x:Static FontIcons.CalculatorAddition}"
                                                                        FontSize="12" />
                                                                </DockPanel>
                                                            </Button.Content>
                                                        </Button>
                                                    </DataTemplate>
                                                </local:ModuleTreeDataTemplateSelector.InputPagePresenterDataTemplate>
                                                <local:ModuleTreeDataTemplateSelector.ModulePresenterDataTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource {x:Static BrushKeys.BorderBrush}}" Style="{DynamicResource {x:Static BorderKeys.Background}}">
                                                            <DockPanel>
                                                                <Button CommandParameter="{Binding ModuleViewPagePresenter}" Style="{StaticResource S.Button.GotoPage}">
                                                                    <TextBlock VerticalAlignment="Center" Text="视图" />
                                                                </Button>
                                                                <Separator Margin="0" Style="{DynamicResource {x:Static SeparatorKeys.Vertical}}" />
                                                                <UniformGrid Columns="1" DockPanel.Dock="Right">
                                                                    <FontIconButton
                                                                        Width="Auto"
                                                                        Height="Auto"
                                                                        VerticalAlignment="Stretch"
                                                                        BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrushTitle}}"
                                                                        BorderThickness="1"
                                                                        Command="{Binding RelativeSource={RelativeSource AncestorType=TreeLayoutBox}, Path=DataContext.AddModuleCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="{x:Static FontIcons.CalculatorAddition}"
                                                                        FontSize="12" />
                                                                    <FontIconButton
                                                                        Width="Auto"
                                                                        Height="Auto"
                                                                        VerticalAlignment="Stretch"
                                                                        BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrushTitle}}"
                                                                        BorderThickness="1"
                                                                        Command="{Binding RelativeSource={RelativeSource AncestorType=TreeLayoutBox}, Path=DataContext.DeleteModuleCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="{x:Static FontIcons.CalculatorSubtract}"
                                                                        FontSize="12" />
                                                                </UniformGrid>
                                                                <Button CommandParameter="{Binding}" Style="{StaticResource S.Button.GotoPage}">
                                                                    <Border>
                                                                        <DockPanel>
                                                                            <FontIconTextBlock Margin="5,0" Text="{Binding Icon}" />
                                                                            <FontIconButton
                                                                                Width="Auto"
                                                                                Height="Auto"
                                                                                Padding="5"
                                                                                Command="{Binding InferenceCommand}"
                                                                                Content="{x:Static FontIcons.Play}"
                                                                                DockPanel.Dock="Right"
                                                                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=(TextBlock.Foreground)}" />
                                                                            <FontIconButton
                                                                                Width="Auto"
                                                                                Height="Auto"
                                                                                Padding="5"
                                                                                Command="{Binding TrainingCommand}"
                                                                                Content="{x:Static FontIcons.People}"
                                                                                DockPanel.Dock="Right"
                                                                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=(TextBlock.Foreground)}" />
                                                                            <TextBlock
                                                                                Margin="10,0"
                                                                                VerticalAlignment="Center"
                                                                                Text="{Binding Name}" />
                                                                        </DockPanel>
                                                                    </Border>
                                                                </Button>
                                                            </DockPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </local:ModuleTreeDataTemplateSelector.ModulePresenterDataTemplate>
                                            </local:ModuleTreeDataTemplateSelector>
                                        </ContentPresenter.ContentTemplateSelector>
                                    </ContentPresenter>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeLayoutBox>
                    </ScrollViewer>
                </DockPanel>
            </Border>
            <ContentPresenter Content="{Binding ProjectItem.SelectedPagePresenter}" />
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>