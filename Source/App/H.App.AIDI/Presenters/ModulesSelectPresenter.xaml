<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:componentmodel="clr-namespace:System.ComponentModel;assembly=WindowsBase"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters">
    <DataTemplate DataType="{x:Type local:ModulesSelectPresenter}">
        <DockPanel>
            <DockPanel.Resources>
                <CollectionViewSource x:Key="Source" Source="{Binding ModulePresenters}">
                    <CollectionViewSource.GroupDescriptions>
                        <PropertyGroupDescription PropertyName="GroupName" />
                    </CollectionViewSource.GroupDescriptions>
                    <CollectionViewSource.SortDescriptions>
                        <componentmodel:SortDescription Direction="Ascending" PropertyName="Order" />
                    </CollectionViewSource.SortDescriptions>
                </CollectionViewSource>
            </DockPanel.Resources>
            <Border
                Width="300"
                Margin="5,0"
                Background="{DynamicResource {x:Static BrushKeys.Dark0_1}}"
                DockPanel.Dock="Right"
                Style="{DynamicResource {x:Static BorderKeys.Background}}">
                <DockPanel>
                    <TextBlock
                        Margin="10"
                        DockPanel.Dock="Top"
                        FontSize="{DynamicResource {x:Static FontSizeKeys.Header4}}"
                        Foreground="{DynamicResource {x:Static BrushKeys.ForegroundTitle}}"
                        LineHeight="20"
                        Text="{Binding SelectedModulePresenter.Name}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="10"
                        FontSize="{DynamicResource {x:Static FontSizeKeys.Header5}}"
                        Foreground="{DynamicResource {x:Static BrushKeys.ForegroundTitle}}"
                        LineHeight="20"
                        Text="{Binding SelectedModulePresenter.Description}"
                        TextWrapping="Wrap" />
                </DockPanel>
            </Border>

            <ListBox
                Cattach.ItemBackground="{DynamicResource {x:Static BrushKeys.Dark0_1}}"
                Cattach.ItemHeight="Auto"
                Cattach.ItemMargin="10"
                Cattach.ItemPadding="10"
                ItemsSource="{Binding Source={StaticResource Source}}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                SelectedItem="{Binding SelectedModulePresenter}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.Panel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </GroupStyle.Panel>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <GroupBox
                                                Cattach.CaptionFontSize="{DynamicResource {x:Static FontSizeKeys.Header5}}"
                                                Cattach.CaptionForeground="{DynamicResource {x:Static BrushKeys.ForegroundTitle}}"
                                                Header="{Binding Name}">
                                                <ItemsPresenter />
                                            </GroupBox>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Width="200" Height="50">
                            <FontIconButton
                                Width="50"
                                Height="50"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource {x:Static BrushKeys.Selected}}"
                                Cattach.CornerRadius="40"
                                Command="{SumitDialogCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                                Content="{x:Static FontIcons.Add}"
                                DockPanel.Dock="Right"
                                FontSize="24">
                                <b:Interaction.Triggers>
                                    <b:EventTrigger EventName="Click">
                                        <b:InvokeCommandAction Command="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=DataContext.AddCommand}" CommandParameter="{Binding}" />
                                    </b:EventTrigger>
                                </b:Interaction.Triggers>
                            </FontIconButton>
                            <FontIconTextBlock
                                Margin="5"
                                DockPanel.Dock="Left"
                                Text="{Binding Icon}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                DockPanel.Dock="Bottom"
                                Text="{Binding Name}" />
                        </DockPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ListBox>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>