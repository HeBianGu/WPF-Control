<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters.Components"
    xmlns:m="clr-namespace:H.App.AIDI.Model">
    <DataTemplate DataType="{x:Type local:ImageViewComponentPresenter}">
        <Grid>
            <Zoombox
                x:Name="zoomview"
                Background="Transparent"
                DragModifiers="Ctrl"
                DragOnPreview="False"
                Focusable="True"
                IsTabStop="True"
                NavigateOnPreview="False"
                RelativeZoomModifiers=""
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                ViewStackIndex="0"
                ZoomOn="Content">
                <Zoombox.ViewStack>
                    <ZoomboxView>Fit</ZoomboxView>
                </Zoombox.ViewStack>
                <b:Interaction.Triggers>
                    <MouseTrigger
                        ClickCount="2"
                        Mode="Right"
                        MouseButton="Left"
                        UseHandle="False">
                        <CallMethodActionEx MethodName="FitToBounds" TargetObject="{Binding ElementName=zoomview}" />
                    </MouseTrigger>
                    <MouseTrigger
                        ClickCount="2"
                        Mode="Left"
                        MouseButton="Left"
                        UseHandle="False">
                        <CallMethodActionEx MethodName="FitToBounds" TargetObject="{Binding ElementName=zoomview}" />
                    </MouseTrigger>
                </b:Interaction.Triggers>
                <Image Source="{Binding Repository.Collection.SelectedItem.Model.Url}" />
            </Zoombox>
            <Border
                Width="300"
                Margin="5"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Style="{DynamicResource {x:Static BorderKeys.Background}}"
                Visibility="{Binding UseImageInfo, Converter={GetTrueToVisibleConverter}}">
                <Border.Background>
                    <SolidColorBrush Opacity="0.7" Color="{DynamicResource {x:Static ColorKeys.MouseOver}}" />
                </Border.Background>
                <StackPanel>
                    <BulletDecorator Margin="5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="导入路径：" />
                        </BulletDecorator.Bullet>
                        <TextBlock
                            Text="{Binding Repository.Collection.SelectedItem.Model.Url}"
                            TextTrimming="WordEllipsis"
                            ToolTip="{Binding RelativeSource={RelativeSource Mode=Self}, Path=Text}" />
                    </BulletDecorator>

                    <BulletDecorator Margin="5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="图像名称：" />
                        </BulletDecorator.Bullet>
                        <TextBlock TextTrimming="WordEllipsis" ToolTip="{Binding RelativeSource={RelativeSource Mode=Self}, Path=Text}">
                            <Run Text="{Binding Repository.Collection.SelectedItem.Model.Name}" /><Run Text="{Binding Repository.Collection.SelectedItem.Model.Extend}" />
                        </TextBlock>
                    </BulletDecorator>

                    <BulletDecorator Margin="5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="原图信息：" />
                        </BulletDecorator.Bullet>
                        <TextBlock Text="{Binding Repository.Collection.SelectedItem.Model.Aspect}" />
                    </BulletDecorator>

                    <BulletDecorator Margin="5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="图像Tag：" />
                        </BulletDecorator.Bullet>
                        <TextBlock Text="{Binding Repository.Collection.SelectedItem.Model.Tags}" />
                    </BulletDecorator>

                    <TextBlock Margin="5">
                        <Hyperlink Foreground="{DynamicResource {x:Static BrushKeys.Accent}}">>快捷键提示</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>