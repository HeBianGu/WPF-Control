<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters.Components"
    xmlns:m="clr-namespace:H.App.AIDI.Model">
    <DataTemplate DataType="{x:Type local:ImageIOComponentPresenter}">
        <Grid>
            <DockPanel
                x:Name="dp_no"
                Width="350"
                Margin="2"
                DockPanel.Dock="Top">
                <FontIconToggleButton
                    CheckedGlyph="{x:Static FontIcons.Pin}"
                    DockPanel.Dock="Right"
                    FontSize="18"
                    IsChecked="{Binding PagePresenter.UseImageIODock}"
                    UncheckedGlyph="{x:Static FontIcons.Pinned}" />
                <UniformGrid Rows="1">
                    <FontIconButton
                        Width="Auto"
                        Command="{Binding ImportImagesCommand}"
                        Content="{x:Static FontIcons.BrowsePhotos}"
                        FontSize="18" />
                    <FontIconButton
                        Width="Auto"
                        Command="{Binding ImportFolderCommand}"
                        Content="{x:Static FontIcons.FolderOpen}"
                        FontSize="18" />
                    <FontIconButton
                        Width="Auto"
                        Command="{ShowNotImplementedCommand}"
                        Content="{x:Static FontIcons.ImageExport}"
                        FontSize="18" />
                </UniformGrid>
            </DockPanel>
            <DockPanel
                x:Name="dp_yes"
                Margin="2"
                DockPanel.Dock="Right">
                <FontIconToggleButton
                    CheckedGlyph="{x:Static FontIcons.Pin}"
                    DockPanel.Dock="Top"
                    FontSize="18"
                    IsChecked="{Binding PagePresenter.UseImageIODock}"
                    UncheckedGlyph="{x:Static FontIcons.Pinned}" />
                <UniformGrid Columns="1">
                    <FontIconButton
                        Margin="0,10"
                        Command="{Binding ImportImagesCommand}"
                        Content="{x:Static FontIcons.BrowsePhotos}"
                        FontSize="18" />
                    <FontIconButton
                        Margin="0,10"
                        Command="{Binding ImportFolderCommand}"
                        Content="{x:Static FontIcons.FolderOpen}"
                        FontSize="18" />
                    <FontIconButton
                        Margin="0,10"
                        Command="{ShowNotImplementedCommand}"
                        Content="{x:Static FontIcons.ImageExport}"
                        FontSize="18" />
                </UniformGrid>
            </DockPanel>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding PagePresenter.UseImageIODock}" Value="True">
                <Setter TargetName="dp_no" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="dp_yes" Property="Visibility" Value="Visible" />
            </DataTrigger>
            <DataTrigger Binding="{Binding PagePresenter.UseImageIODock}" Value="False">
                <Setter TargetName="dp_yes" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="dp_no" Property="Visibility" Value="Visible" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
</ResourceDictionary>