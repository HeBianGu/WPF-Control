<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:db="clr-namespace:H.App.AIDI.DB"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters.Components">
    <DataTemplate DataType="{x:Type local:ImageListComponentPresenter}">
        <DockPanel Width="160" Margin="5">
            <DockPanel DockPanel.Dock="Top">
                <TextFilterBox
                    x:Name="tfb"
                    Cattach.Icon="{x:Static FontIcons.Search}"
                    Cattach.TitleWidth="0"
                    PropertyNames="Name">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="FilterChanged">
                            <b:ChangePropertyAction
                                PropertyName="Filter2"
                                TargetObject="{Binding Repository.Collection}"
                                Value="{Binding ElementName=tfb, Path=Filter}" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </TextFilterBox>
                <!--<FontIconButton Content="{x:Static FontIcons.RepeatAll}" DockPanel.Dock="Right" />
                <TextBox Cattach.Icon="{x:Static FontIcons.Search}" Style="{DynamicResource {x:Static TextBoxKeys.Attach}}" />-->
            </DockPanel>

            <DockPanel DockPanel.Dock="Top">
                <PropertyFilterBox
                    Margin="0,2"
                    HorizontalAlignment="Stretch"
                    Type="{x:Type db:fm_dd_image}">
                    <!--<PropertyFilterBox.DefinePropertyConditionPrensenters>
                        <PropertyConditionPrensenter ID="训练集">
                            <PropertyConfidtion>
                                <EnumPropertyFilter
                                    Operate="Equals"
                                    PropertyName="DatasetType"
                                    Value="Train" />
                            </PropertyConfidtion>
                        </PropertyConditionPrensenter>
                        <PropertyConditionPrensenter ID="测试集">
                            <PropertyConfidtion>
                                <EnumPropertyFilter
                                    Operate="Equals"
                                    PropertyName="DatasetType"
                                    Value="Test" />
                            </PropertyConfidtion>
                        </PropertyConditionPrensenter>
                        <PropertyConditionPrensenter ID="已标注">
                            <PropertyConfidtion>
                                <EnumPropertyFilter
                                    Operate="Greater"
                                    PropertyName="LabelsCount"
                                    Value="0" />
                            </PropertyConfidtion>
                        </PropertyConditionPrensenter>
                        <PropertyConditionPrensenter ID="漏检">
                            <PropertyConfidtion>
                                <EnumPropertyFilter
                                    Operate="Greater"
                                    PropertyName="LabelsCount"
                                    Value="0" />
                            </PropertyConfidtion>
                        </PropertyConditionPrensenter>
                        <PropertyConditionPrensenter ID="过检">
                            <PropertyConfidtion>
                                <EnumPropertyFilter
                                    Operate="Greater"
                                    PropertyName="LabelsCount"
                                    Value="0" />
                            </PropertyConfidtion>
                        </PropertyConditionPrensenter>
                        <PropertyConditionPrensenter ID="错检">
                            <PropertyConfidtion>
                                <EnumPropertyFilter
                                    Operate="Greater"
                                    PropertyName="LabelsCount"
                                    Value="0" />
                            </PropertyConfidtion>
                        </PropertyConditionPrensenter>
                    </PropertyFilterBox.DefinePropertyConditionPrensenters>-->
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="FilterChanged">
                            <b:ChangePropertyAction
                                PropertyName="Filter1"
                                TargetObject="{Binding Repository.Collection}"
                                Value="{Binding RelativeSource={RelativeSource AncestorType=PropertyFilterBox}, Path=Filter}" />
                        </b:EventTrigger>
                        <b:EventTrigger EventName="Loaded">
                            <b:ChangePropertyAction
                                PropertyName="Filter1"
                                TargetObject="{Binding Repository.Collection}"
                                Value="{Binding RelativeSource={RelativeSource AncestorType=PropertyFilterBox}, Path=Filter}" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </PropertyFilterBox>
            </DockPanel>

            <DockPanel Margin="0,2" DockPanel.Dock="Top">
                <PropertyOrderBox HorizontalAlignment="Stretch" Type="{x:Type db:fm_dd_image}">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="OrderChanged">
                            <b:ChangePropertyAction
                                PropertyName="Order1"
                                TargetObject="{Binding Repository.Collection}"
                                Value="{Binding RelativeSource={RelativeSource AncestorType=PropertyOrderBox}, Path=Order}" />
                        </b:EventTrigger>
                        <b:EventTrigger EventName="Loaded">
                            <b:ChangePropertyAction
                                PropertyName="Order1"
                                TargetObject="{Binding Repository.Collection}"
                                Value="{Binding RelativeSource={RelativeSource AncestorType=PropertyOrderBox}, Path=Order}" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </PropertyOrderBox>
            </DockPanel>
            <DockPanel DockPanel.Dock="Top">
                <FontIconButton
                    Command="{Binding RefreshDataCommand}"
                    Content="{x:Static FontIcons.Refresh}"
                    DockPanel.Dock="Right" />
                <CheckBox Content="全选" IsChecked="{Binding Repository.CheckedAll}" />
                <TextBlock Margin="10,0" VerticalAlignment="Center">
                    <Run Text="{Binding Repository.Collection.FilterSource.Count, Mode=OneWay}" />
                    <Run Text="/" />
                    <Run Text="{Binding Repository.Collection.Count, Mode=OneWay}" />
                </TextBlock>
            </DockPanel>
            <ListBox
                Cattach.ItemHeight="Auto"
                Cattach.ItemPadding="0"
                ItemsSource="{Binding Repository.Collection.FilterSource}"
                SelectedItem="{Binding Repository.Collection.SelectedItem}"
                SelectionMode="Single">
                <ItemsControl.ContextMenu>
                    <ContextMenu ItemContainerStyle="{DynamicResource {x:Static MenuItemKeys.BindCommand}}">
                        <MenuItem Command="{Binding Repository.DeleteCommand}" Header="删除" />
                        <MenuItem Command="{Binding Repository.EditCommand}" Header="编辑" />
                        <MenuItem Command="{Binding Repository.ViewCommand}" Header="查看" />
                        <MenuItem Command="{Binding Repository.DeleteCheckedCommand}" Header="删除选中" />
                        <MenuItem Command="{Binding Repository.ClearCommand}" Header="清空" />
                        <MenuItem Command="{Binding Repository.CheckedAllCommand}" Header="全选" />
                    </ContextMenu>
                </ItemsControl.ContextMenu>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="{DynamicResource {x:Static LayoutKeys.CornerRadius}}">
                            <b:Interaction.Behaviors>
                                <BorderClipCornerRadiusBehavior />
                            </b:Interaction.Behaviors>
                            <Grid Height="100">
                                <Image Source="{Binding Model.Url}" />
                                <Border
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource {x:Static BrushKeys.Red}}"
                                    CornerRadius="0 0 2 0">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="White"
                                        TextAlignment="Center">
                                        <b:Interaction.Behaviors>
                                            <TextBlockIndexOfBebavior Item="{Binding}" Source="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ItemsSource}">
                                                <TextBlockIndexOfBebavior.Format>{0}</TextBlockIndexOfBebavior.Format>
                                            </TextBlockIndexOfBebavior>
                                        </b:Interaction.Behaviors>
                                    </TextBlock>
                                </Border>
                                <Border
                                    x:Name="b_dataset"
                                    Width="40"
                                    Height="40"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource {x:Static BrushKeys.Green}}"
                                    RenderTransformOrigin="0 0">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform Angle="-45" />
                                            <TranslateTransform X="25" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                </Border>
                                <CheckBox
                                    Height="Auto"
                                    Margin="0,2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=DataContext.Repository.UpdateCheckAllCommand}"
                                    IsChecked="{Binding IsSelected}" />
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Model.DatasetType}" Value="Train">
                                <Setter TargetName="b_dataset" Property="Background" Value="{DynamicResource {x:Static BrushKeys.Green}}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Model.DatasetType}" Value="Test">
                                <Setter TargetName="b_dataset" Property="Background" Value="{DynamicResource {x:Static BrushKeys.Red}}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Model.DatasetType}" Value="Validation">
                                <Setter TargetName="b_dataset" Property="Background" Value="{DynamicResource {x:Static BrushKeys.Orange}}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemContainerStyle>
                    <Style BasedOn="{StaticResource {x:Static ListBoxItemKeys.Default}}" TargetType="{x:Type ListBoxItem}">
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Background" Value="{DynamicResource {x:Static BrushKeys.Dark0_1}}" />
                        <Setter Property="Margin" Value="0,2" />
                        <!--<Setter Property="IsSelected" Value="{Binding IsSelected}"/>-->
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static BrushKeys.Accent}}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <!--<b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding Repository.UpdateCheckAllCommand}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>-->
            </ListBox>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>