<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.App.AIDI.Presenters.Components"
    xmlns:m="clr-namespace:H.App.AIDI.Model">
    <DataTemplate DataType="{x:Type local:TagManagerComponentPresenter}">
        <GroupBox
            DockPanel.Dock="Right"
            Header="图像Tag">
            <Cattach.CaptionRightTemplate>
                <ControlTemplate>
                    <DockPanel>
                        <Button
                            Height="Auto"
                            HorizontalAlignment="Right"
                            Command="{CreateTagCommand}"
                            Content="新增"
                            ToolTip="新增Tag" />
                        <Button
                            Height="Auto"
                            HorizontalAlignment="Right"
                            Command="{ManageTagCommand}"
                            Content="管理"
                            ToolTip="管理Tag" />
                    </DockPanel>
                </ControlTemplate>
            </Cattach.CaptionRightTemplate>
            <TagBox ItemsSource="{Binding Source={x:Static IocTagService.Instance},Path=Collection}" SelectedTags="{Binding Repository.Collection.SelectedItem.Model.Tags, Mode=TwoWay}" />
        </GroupBox>
    </DataTemplate>
</ResourceDictionary>