<h:MainWindow
    x:Class="H.App.AIDI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.App.AIDI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="1200"
    Height="750"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>
    <h:MainWindow.CaptionTempate>
        <ControlTemplate>
            <DockPanel LastChildFill="False" WindowChrome.IsHitTestVisibleInChrome="True">
                <Menu>
                    <Menu.Resources>
                        <Style BasedOn="{StaticResource {x:Static MenuItemKeys.BindCommand}}" TargetType="MenuItem" />
                    </Menu.Resources>
                    <MenuItem
                        Background="Transparent"
                        Header="文件"
                        ToolTip="项目文件管理:新增、修改、选择、删除和最近的项目等">
                        <MenuItem Command="{ShowNewProjectCommand}" />
                        <MenuItem Command="{ShowProjectsCommand}" />
                        <MenuItem Command="{ShowEditProjectCommand}" />
                        <MenuItem Command="{ShowSaveProjectCommand}" />
                        <MenuItem Command="{ShowCurrentProjectFileCommand}" />
                        <MenuItem Command="{ShowCloseProjectCommand}" />
                        <MenuItem
                            Cattach.Icon="{x:Static FontIcons.Calendar}"
                            Header="最近的项目"
                            ItemsSource="{Binding Source={x:Static IocProject.Instance}, Path=Collection}">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Command" Value="{ShowOpenProjectCommand}" />
                                    <Setter Property="CommandParameter" Value="{Binding}" />
                                    <Setter Property="Height" Value="50" />
                                    <Setter Property="MinWidth" Value="400" />
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                        <Separator />
                        <MenuItem
                            Cattach.Icon="{x:Static FontIcons.PowerButton}"
                            Command="{CloseAfterSaveWindowCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Header="退出" />
                    </MenuItem>
                    <MenuItem
                        Background="Transparent"
                        Header="版本"
                        ToolTip="项目文件管理:新增、修改、选择、删除和最近的项目等">
                        <MenuItem Command="{ShowDisableCommand}" Header="保存当前为版本" />
                        <MenuItem Command="{ShowDisableCommand}" Header="回退至最近版本" />
                        <MenuItem Command="{ShowDisableCommand}" Header="管理已有版本" />
                    </MenuItem>
                    <MenuItem
                        Background="Transparent"
                        Header="工具"
                        ToolTip="项目文件管理:新增、修改、选择、删除和最近的项目等">
                        <MenuItem Command="{ShowDisableCommand}" Header="工厂模式" />
                        <MenuItem Command="{ShowDisableCommand}" Header="综合判定工具" />
                        <MenuItem Command="{ShowDisableCommand}" Header="导出报表" />
                    </MenuItem>
                    <MenuItem
                        Background="Transparent"
                        Header="图像"
                        ToolTip="项目文件管理:新增、修改、选择、删除和最近的项目等">
                        <MenuItem Command="{ShowDisableCommand}" Header="导入图像" />
                        <MenuItem Command="{ShowDisableCommand}" Header="导入文件夹" />
                        <MenuItem Command="{ShowDisableCommand}" Header="导出图像" />
                    </MenuItem>
                    <MenuItem
                        Background="Transparent"
                        Header="训练推理"
                        ToolTip="项目文件管理:新增、修改、选择、删除和最近的项目等">
                        <MenuItem Command="{ShowDisableCommand}" Header="训练当前模块" />
                        <MenuItem Command="{ShowDisableCommand}" Header="推理当前模块" />
                        <MenuItem Command="{ShowDisableCommand}" Header="训练任务管理" />
                        <Separator />
                        <MenuItem Command="{ShowDisableCommand}" Header="一键推理所有图像" />
                        <MenuItem Command="{ShowDisableCommand}" Header="一键推理新增图像" />
                    </MenuItem>
                    <MenuItem
                        Background="Transparent"
                        Header="模型"
                        ToolTip="项目文件管理:新增、修改、选择、删除和最近的项目等">
                        <MenuItem Command="{ShowDisableCommand}" Header="模型导出" />
                        <MenuItem Command="{ShowDisableCommand}" Header="模型与示例代码导出" />
                        <MenuItem Command="{ShowDisableCommand}" Header="训练过程曲线" />
                        <Separator />
                        <MenuItem Command="{ShowDisableCommand}" Header="模型耗时" />
                        <MenuItem Command="{ShowDisableCommand}" Header="模型信息" />
                    </MenuItem>
                    <MenuItem
                        Background="Transparent"
                        Header="设置"
                        ToolTip="项目文件管理:新增、修改、选择、删除和最近的项目等">
                        <MenuItem Command="{ShowSettingCommand}" Header="首选项" />
                        <MenuItem Command="{ShowDisableCommand}" Header="硬件选择" />
                        <MenuItem Command="{ShowDisableCommand}" Header="内置函数模板管理" />
                        <MenuItem Command="{ShowDisableCommand}" Header="工程体积优化" />
                    </MenuItem>
                    <MenuItem Header="帮助" ToolTip="新手向导、技术支持、关于、反馈、官网、联系方式和开发文档等">
                        <MenuItem Command="{ShowGuideCommand}" />
                        <MenuItem Command="{ShowNewGuideCommand}" />
                        <MenuItem Command="{ShowGuideTreeCommand}" />
                        <MenuItem Command="{ShowNewGuideTreeCommand}" />
                        <Separator />
                        <MenuItem Command="{ShowNotImplementedCommand}" Header="检查更新" />
                        <MenuItem Command="{ShowNotImplementedCommand}" Header="注册" />

                        <MenuItem Command="{ShowReleaseVersionsCommand}" />
                        <MenuItem Command="{ShowSupportCommand}" />
                        <MenuItem Command="{ShowFeedbackCommand}" />
                        <MenuItem Command="{ShowWebSiteCommand}" />
                        <Separator />
                        <MenuItem Command="{ShowContactCommand}">
                            <MenuItem Command="{ShowGithubContactCommand}" />
                            <MenuItem Command="{ShowGitHubIssueContactCommand}" />
                            <MenuItem Command="{ShowQQContactCommand}" />
                            <MenuItem Command="{ShowSendMailContactCommand}" />
                            <MenuItem Command="{ShowBlogContactCommand}" />
                            <MenuItem Command="{ShowPodcastContactCommand}" />
                        </MenuItem>
                        <MenuItem Command="{ShowPrivacyCommand}">
                            <MenuItem Command="{ShowAgreementCommand}" />
                            <MenuItem Command="{ShowPrivacyCommand}" />
                        </MenuItem>
                        <MenuItem Command="{ShowSponsorCommand}" />
                        <MenuItem Command="{ShowAboutCommand}" />
                    </MenuItem>
                </Menu>

                <FontIconButton
                    Command="{ShowSettingCommand}"
                    DockPanel.Dock="Right"
                    Style="{DynamicResource {x:Static FontIconButtonKeys.Command}}" />
                <FontIconButton
                    Command="{ShowColorThemeViewCommand}"
                    DockPanel.Dock="Right"
                    Style="{DynamicResource {x:Static FontIconButtonKeys.Command}}" />
                <Button
                    Command="{ShowSettingCommand SwitchToType={x:Type h:IThemeOptions}}"
                    Content="{Binding Source={x:Static h:ThemeOptions.Instance}, Path=ColorResource.Name}"
                    DockPanel.Dock="Right" />
                <ContentPresenter Content="{Ioc Type={x:Type ISwitchThemeViewPresenter}}" DockPanel.Dock="Right" />
            </DockPanel>
        </ControlTemplate>
    </h:MainWindow.CaptionTempate>
    <HomeBox />
</h:MainWindow>
