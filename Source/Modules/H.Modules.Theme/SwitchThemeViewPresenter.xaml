<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:p="clr-namespace:H.Modules.Theme.Properties"
    xmlns:local="clr-namespace:H.Modules.Theme">
    <DataTemplate DataType="{x:Type local:SwitchThemeViewPresenter}">
        <FontIconToggleButton
            CheckedGlyph="&#xE706;"
            Command="{Binding SwitchDarkCommand}"
            IsChecked="{Binding Source={x:Static local:ThemeOptions.Instance}, Path=IsDark}"
            Style="{DynamicResource {x:Static FontIconToggleButtonKeys.Switch}}"
            ToolTip="{x:Static p:Resources.SwitchTheme}"
            UncheckedGlyph="&#xE708;"
            WindowChrome.IsHitTestVisibleInChrome="True">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="Loaded">
                    <b:InvokeCommandAction Command="{Binding LoadedCommand}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>
        </FontIconToggleButton>
    </DataTemplate>
</ResourceDictionary>