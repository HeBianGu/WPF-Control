<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                    xmlns:h="https://github.com/HeBianGu"
                    xmlns:p="clr-namespace:H.Modules.Login.Properties"
                    xmlns:local="clr-namespace:H.Modules.Login.Presenters">
    <DataTemplate DataType="{x:Type local:BackgroundLoginViewPresenter}">
        <Grid Width="900"
              Height="450">
            <Border Width="310"
                    Margin="51,21,51,31"
                    HorizontalAlignment="Right"
                    CornerRadius="5"
                    Style="{DynamicResource {x:Static BorderKeys.Effect}}" />
            <Border Width="310"
                    Margin="50,20,50,30"
                    HorizontalAlignment="Right"
                    Background="White"
                    CornerRadius="5">
                <!--  登录页面  -->
                <StackPanel x:Name="g_login"
                            Margin="20"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">
                    <Viewbox Margin="0,5">
                        <TextBlock HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="24"
                                   Foreground="Black"
                                   Text="{x:Static ApplicationProvider.Product}" />
                    </Viewbox>
                    <TextBlock Margin="0,20"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="ExtraBold"
                               Foreground="{DynamicResource {x:Static BrushKeys.Accent}}"
                               Text="{x:Static p:Resources.AccountLogin}" />
                    <!--  用户名  -->
                    <TextBox HorizontalAlignment="Stretch"
                             Cattach.TitleBackground="{x:Null}"
                             Cattach.Watermark="{x:Static p:Resources.InputAccount}"
                             Style="{DynamicResource {x:Static TextBoxKeys.Delete}}"
                             Text="{Binding UserName}">
                        <Cattach.Title>
                            <FontIconTextBlock FontSize="14"
                                               Text="{x:Static FontIcons.StatusCircleErrorX}" />
                        </Cattach.Title>
                    </TextBox>
                    <!--  密码  -->
                    <Control Margin="0,20,0,10">
                        <Control.Template>
                            <ControlTemplate>
                                <Grid>
                                    <PasswordBox x:Name="p"
                                                 Cattach.Password="{Binding Password, Mode=TwoWay}"
                                                 Cattach.TitleBackground="{x:Null}"
                                                 Cattach.Watermark="{x:Static p:Resources.InputPassword}"
                                                 Style="{DynamicResource {x:Static PasswordBoxKeys.Attach}}">
                                        <Cattach.Title>
                                            <FontIconTextBlock Margin="-2,0,0,0"
                                                               FontSize="14"
                                                               Text="{x:Static FontIcons.Lock}" />
                                        </Cattach.Title>
                                    </PasswordBox>
                                    <TextBox x:Name="t"
                                             Cattach.TitleBackground="{x:Null}"
                                             Cattach.Watermark="{x:Static p:Resources.InputPassword}"
                                             Style="{DynamicResource {x:Static TextBoxKeys.Attach}}"
                                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}">
                                        <Cattach.Title>
                                            <FontIconTextBlock FontSize="14"
                                                               Text="{x:Static FontIcons.Lock}" />
                                        </Cattach.Title>
                                    </TextBox>
                                    <FontIconToggleButton HorizontalAlignment="Right"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          CheckedGlyph="&#xE890;"
                                                          IsChecked="{Binding ShowPassword, Mode=TwoWay}"
                                                          UncheckedGlyph="&#xECE4;" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ShowPassword}"
                                                 Value="True">
                                        <Setter TargetName="t" Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ShowPassword}"
                                                 Value="False">
                                        <Setter TargetName="p" Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Error, Converter={x:Static Converter.GetNullToCollapsed}}"
                                                 Value="True">
                                        <Setter TargetName="t" Property="BorderBrush" Value="{DynamicResource {x:Static BrushKeys.Red}}" />
                                        <Setter TargetName="p" Property="BorderBrush" Value="{DynamicResource {x:Static BrushKeys.Red}}" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Control>

                    <!--  错误提示  -->
                    <Control Margin="5">
                        <Control.Template>
                            <ControlTemplate>
                                <DockPanel x:Name="d_error">
                                    <FontIconTextBlock Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                                                       Text="&#xE783;" />
                                    <TextBlock Margin="2,0"
                                               Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                                               Text="{Binding Error}" />
                                </DockPanel>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Error}"
                                                 Value="{x:Null}">
                                        <Setter TargetName="d_error" Property="Visibility" Value="Hidden" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Control>
                    <!--  登录  -->
                    <CheckBox Margin="5"
                              HorizontalAlignment="Right"
                              Content="{x:Static p:Resources.RemenberPassword}"
                              IsChecked="{Binding Source={x:Static h:LoginOptions.Instance}, Path=Remember}" />
                    <h:ProgressButton HorizontalAlignment="Stretch"
                                      Command="{Binding LoginCommand}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type h:IDialog}}}"
                                      Content="{x:Static p:Resources.Login}">
                        <h:ProgressButton.Style>
                            <Style BasedOn="{StaticResource {x:Static h:ProgressButton.CommandKey}}"
                                   TargetType="ProgressButton">
                                <Setter Property="Background" Value="{DynamicResource {x:Static BrushKeys.Accent}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static BrushKeys.White}}" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="true">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Opacity="0.9"
                                                                 Color="{DynamicResource {x:Static ColorKeys.Accent}}" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="{DynamicResource {x:Static BrushKeys.White}}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </h:ProgressButton.Style>
                    </h:ProgressButton>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>