<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:lc="clr-namespace:H.Modules.Login.Commands"
    xmlns:local="clr-namespace:H.Modules.Login.Presenters">
    <DataTemplate DataType="{x:Type local:CurrentUserViewPresenter}">
        <StackPanel MinWidth="400">
            <DockPanel HorizontalAlignment="Right" DockPanel.Dock="Top">
                <FontIconButton Command="{lc:LogoutCommand}" Style="{DynamicResource {x:Static FontIconButtonKeys.Command}}" />
                <FontIconButton Command="{lc:SwitchUserCommand}" Style="{DynamicResource {x:Static FontIconButtonKeys.Command}}" />
            </DockPanel>
            <!--<BulletDecorator>
                <BulletDecorator.Bullet>
                    <TextBlock Text="用户名" />
                </BulletDecorator.Bullet>
                <TextBlock Text="{Binding Name}" />
            </BulletDecorator>

            <BulletDecorator>
                <BulletDecorator.Bullet>
                    <TextBlock Text="角色" />
                </BulletDecorator.Bullet>
                <TextBlock Text="{Binding Role}" />
            </BulletDecorator>-->
            <Form SelectObject="{Binding Source={Ioc Type={x:Type ILoginService}}, Path=User}"
                  UsePropertyView="True"
                  UsePropertyNames="Name,Account" />
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>