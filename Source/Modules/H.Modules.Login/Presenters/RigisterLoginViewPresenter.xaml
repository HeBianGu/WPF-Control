<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                    xmlns:l="clr-namespace:H.Modules.Login"
                    xmlns:p="clr-namespace:H.Modules.Login.Properties"
                    xmlns:local="clr-namespace:H.Modules.Login.Presenters"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">
    <DataTemplate DataType="{x:Type local:RigisterLoginViewPresenter}">
        <Border Width="600"
                Height="Auto"
                Margin="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Margin="5,0,5,6"
                        BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrush}}"
                        BorderThickness="0,0,0,0">
                    <Image Source="{Binding Source={x:Static l:RegistorOptions.Instance}, Path=Image}" />
                </Border>

                <Border Grid.ColumnSpan="2"
                        VerticalAlignment="Top">
                    <Grid Margin="2,1,2,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid x:Name="PART_Header"
                              Grid.ColumnSpan="3"
                              Margin="15,1,15,1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Orientation="Horizontal">
                                <TextBlock FontWeight="Bold" />

                                <TextBlock Margin="5"
                                           VerticalAlignment="Center"
                                           Text="{Binding Title}" />
                            </StackPanel>

                            <Image Margin="0,40"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel Grid.Column="3"
                                    Margin="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Orientation="Horizontal"/>
                    </Grid>
                </Border>

                <ListBox Grid.Column="1"
                         Margin="20,0,0,0"
                         VerticalAlignment="Center"
                         ClipToBounds="True"
                         Foreground="{DynamicResource {x:Static BrushKeys.Foreground}}"
                         SelectedIndex="{Binding SelectedIndex}">
                    <!--  用户登录  -->
                    <StackPanel>
                        <TextBlock Margin="10,0,10,20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="25"
                                   Text="{x:Static p:Resources.UserLogin}" />
                        <BulletDecorator Margin="0,1">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="60"
                                           Text="{x:Static p:Resources.Account}" />
                            </BulletDecorator.Bullet>
                            <TextBox Text="{Binding UserName}" />
                        </BulletDecorator>
                        <!--<TextBox
                            Cattach.Title="账号"
                            Cattach.TitleWidth="60"
                            Cattach.Watermark="输入账号"
                            Style="{DynamicResource {x:Static TextBoxKeys.Attach}}"
                            Text="{Binding UserName}" />
                        <PasswordBox
                            Cattach.Title="密码"
                            Cattach.TitleWidth="60"
                            Cattach.Watermark="输入密码"
                            Style="{DynamicResource {x:Static PasswordBoxKeys.Attach}}"
                            Text="{Binding UserName}" />-->

                        <BulletDecorator Margin="0,1">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="60"
                                           Text="{x:Static p:Resources.Password}" />
                            </BulletDecorator.Bullet>
                            <PasswordBox>
                                <b:Interaction.Behaviors>
                                    <PasswordBindingBehavior Password="{Binding Password, Mode=TwoWay}" />
                                </b:Interaction.Behaviors>
                            </PasswordBox>
                        </BulletDecorator>

                        <Grid Height="{DynamicResource {x:Static LayoutKeys.ItemHeight}}"
                              Margin="0,1">
                            <CheckBox HorizontalAlignment="Right"
                                      Content="{x:Static p:Resources.RemenberPassword}"
                                      IsChecked="{Binding Source={x:Static LoginOptions.Instance}, Path=Remember}" />

                            <Button Padding="0"
                                    HorizontalAlignment="Left"
                                    Background="Transparent"
                                    Command="{Binding GotoForgetCommand}"
                                    Content="{x:Static p:Resources.ForgetPassword}"
                                    Visibility="{Binding Source={x:Static RegistorOptions.Instance}, Path=UseMail, Converter={x:Static Converter.GetTrueToVisible}}" />
                        </Grid>


                        <ProgressButton HorizontalAlignment="Stretch"
                                        Command="{Binding LoginCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type IDialog}}}"
                                        Content="{x:Static p:Resources.Login}" />

                        <TextBlock Margin="5"
                                   HorizontalAlignment="Center"
                                   DockPanel.Dock="Bottom">
                            <Hyperlink Command="{Binding GotoMailCommand}"
                                       Foreground="{DynamicResource {x:Static BrushKeys.Foreground}}">
                              <Run Text="{x:Static p:Resources.RegisterNow}"/>
                            </Hyperlink>
                        </TextBlock>
                        <!--<Button
                            Margin="0,1"
                            Background="Transparent"
                            Command="{Binding GotoMailCommand}"
                            Content="立即注册"
                            DockPanel.Dock="Bottom" />-->
                    </StackPanel>

                    <!--  邮箱验证  -->
                    <StackPanel>
                        <TextBlock Margin="10"
                                   HorizontalAlignment="Center"
                                   DockPanel.Dock="Top"
                                   FontSize="25"
                                   Text="{x:Static p:Resources.EmailVerification}" />
                        <BulletDecorator Margin="0,2"
                                         VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="80"
                                           Text="{x:Static p:Resources.EmailAddress}" />
                            </BulletDecorator.Bullet>
                            <TextBox Text="{Binding MailVerify.Mail, UpdateSourceTrigger=PropertyChanged}" />
                        </BulletDecorator>

                        <BulletDecorator Margin="0,2"
                                         VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="80"
                                           Text="{x:Static p:Resources.VerificationCode}" />
                            </BulletDecorator.Bullet>
                            <DockPanel>
                                <ProgressButton Command="{Binding GetVerifyCodeCommand}"
                                                Content="{x:Static p:Resources.GetVerificationCode}"
                                                DockPanel.Dock="Right"
                                                Message="{x:Static p:Resources.SendingEmail}" />
                                <TextBox Text="{Binding MailVerify.InputCode, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </BulletDecorator>


                        <DockPanel Margin="0,2"
                                   LastChildFill="False">
                            <CheckBox IsChecked="{Binding MailVerify.Agree}" />
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="{x:Static p:Resources.Agree}" />
                                <Hyperlink Command="{ProcessCommand}"
                                           CommandParameter="{Binding Source={x:Static l:RegistorOptions.Instance}, Path=ServiceAgreementUri}">
                                    <TextBlock Text="{x:Static p:Resources.ServiceAgreement}" />
                                </Hyperlink>
                                <Run Text="{x:Static p:Resources.And}" />
                                <Hyperlink Command="{ProcessCommand}"
                                           CommandParameter="{Binding Source={x:Static l:RegistorOptions.Instance}, Path=PrivacypolicyUri}">
                                    <TextBlock Text="{x:Static p:Resources.Privacypolicy}" />
                                </Hyperlink>
                            </TextBlock>
                        </DockPanel>

                        <Button Grid.Row="4"
                                Width="Auto"
                                Cattach.BuzyText="{x:Static p:Resources.Invoking}"
                                Command="{Binding GotoNextCommand}"
                                Content="{x:Static p:Resources.Next}" />

                        <Button Background="Transparent"
                                Command="{Binding GotoLoginCommand}"
                                Content="{x:Static p:Resources.LoginDirect}"
                                DockPanel.Dock="Bottom" />

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   DockPanel.Dock="Bottom"
                                   Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                                   Text="{Binding MailVerify.Message}"
                                   TextWrapping="Wrap"
                                   ToolTip="{Binding RelativeSource={RelativeSource Mode=Self}, Path=Text}" />
                    </StackPanel>

                    <!--  用户注册  -->
                    <StackPanel>
                        <TextBlock Margin="10"
                                   HorizontalAlignment="Center"
                                   DockPanel.Dock="Top"
                                   FontSize="25"
                                   Text="{x:Static p:Resources.RegisterAccount}" />

                        <BulletDecorator Margin="0,1"
                                         VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="80"
                                           Text="{x:Static p:Resources.Account}" />
                            </BulletDecorator.Bullet>
                            <TextBox Text="{Binding Registor.UserName, UpdateSourceTrigger=PropertyChanged}" />
                        </BulletDecorator>

                        <BulletDecorator Margin="0,1"
                                         VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="80"
                                           Text="{x:Static p:Resources.Password}" />
                            </BulletDecorator.Bullet>
                            <PasswordBox>
                                <b:Interaction.Behaviors>
                                    <PasswordBindingBehavior Password="{Binding Registor.Password, Mode=TwoWay}" />
                                </b:Interaction.Behaviors>
                            </PasswordBox>
                        </BulletDecorator>

                        <BulletDecorator Margin="0,1"
                                         VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="80"
                                           Text="{x:Static p:Resources.ConfirmationPassword}" />
                            </BulletDecorator.Bullet>
                            <PasswordBox>
                                <b:Interaction.Behaviors>
                                    <PasswordBindingBehavior Password="{Binding Registor.VerifyPassword, Mode=TwoWay}" />
                                </b:Interaction.Behaviors>
                            </PasswordBox>
                        </BulletDecorator>

                        <Button Width="Auto"
                                Margin="0,1"
                                Command="{Binding GotoMailCommand}"
                                Content="{x:Static p:Resources.Previous}"
                                Visibility="{Binding Source={x:Static l:RegistorOptions.Instance}, Path=UseMail, Converter={x:Static Converter.GetTrueToVisible}}" />

                        <!--<Button Width="Auto"
                                Margin="0,2"
                                Command="{Binding RegisterCommand}"
                                Content="注册" />-->


                        <ProgressButton Margin="0,1"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding RegisterCommand}"
                                        Content="{x:Static p:Resources.Register}" />

                        <TextBlock Margin="5"
                                   HorizontalAlignment="Center"
                                   DockPanel.Dock="Bottom">
                            <Hyperlink Command="{Binding GotoLoginCommand}"
                                       Foreground="{DynamicResource {x:Static BrushKeys.Foreground}}">
                                <Run Text="{x:Static p:Resources.LoginDirect}"/>
                            </Hyperlink>
                        </TextBlock>

                        <!--<Button
                            Margin="0,1"
                            Background="Transparent"
                            Command="{Binding GotoLoginCommand}"
                            Content="直接登录"
                            DockPanel.Dock="Bottom" />-->

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   DockPanel.Dock="Bottom"
                                   Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                                   Text="{Binding Registor.Message}"
                                   ToolTip="{Binding RelativeSource={RelativeSource Mode=Self}, Path=Text}" />
                    </StackPanel>

                    <!--  修改密码  -->
                    <StackPanel>
                        <TextBlock Margin="10"
                                   HorizontalAlignment="Center"
                                   DockPanel.Dock="Top"
                                   FontSize="25"
                                   Text="{x:Static p:Resources.ChangePassword}" />

                        <BulletDecorator Margin="0,2">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="80"
                                           Text="{x:Static p:Resources.Account}" />
                            </BulletDecorator.Bullet>
                            <TextBox IsReadOnly="True"
                                     Text="{Binding UserName}" />
                        </BulletDecorator>

                        <BulletDecorator Margin="0,2"
                                         VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="80"
                                           Text="{x:Static p:Resources.Password}" />
                            </BulletDecorator.Bullet>
                            <PasswordBox>
                                <b:Interaction.Behaviors>
                                    <PasswordBindingBehavior Password="{Binding Forget.Password, Mode=TwoWay}" />
                                </b:Interaction.Behaviors>
                            </PasswordBox>
                        </BulletDecorator>


                        <BulletDecorator Margin="0,2"
                                         VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <TextBlock Width="80"
                                           Text="{x:Static p:Resources.ConfirmationPassword}" />
                            </BulletDecorator.Bullet>
                            <PasswordBox>
                                <b:Interaction.Behaviors>
                                    <PasswordBindingBehavior Password="{Binding Forget.VerifyPassword, Mode=TwoWay}" />
                                </b:Interaction.Behaviors>
                            </PasswordBox>
                        </BulletDecorator>

                        <Button Width="Auto"
                                Margin="0,2"
                                Command="{Binding GotoMailCommand}"
                                Content="{x:Static p:Resources.Previous}"
                                Visibility="{Binding Source={x:Static l:RegistorOptions.Instance}, Path=UseMail, Converter={x:Static Converter.GetTrueToVisible}}" />

                        <ProgressButton Width="Auto"
                                        Margin="0,2"
                                        Command="{Binding ChangePasswordCommand}"
                                        Content="{x:Static p:Resources.Change}" />

                        <Button Background="Transparent"
                                Command="{Binding GotoLoginCommand}"
                                Content="{x:Static p:Resources.LoginDirect}"
                                DockPanel.Dock="Bottom" />

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   DockPanel.Dock="Bottom"
                                   Foreground="{DynamicResource {x:Static BrushKeys.Red}}"
                                   Text="{Binding Forget.Message}"
                                   ToolTip="{Binding RelativeSource={RelativeSource Mode=Self}, Path=Text}" />
                    </StackPanel>

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Grid IsItemsHost="True" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <ItemsPresenter />
                        </ControlTemplate>
                    </ListBox.Template>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Visibility" Value="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsSelected, Converter={x:Static Converter.GetTrueToVisible}}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>