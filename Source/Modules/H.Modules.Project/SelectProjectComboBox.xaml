<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:H.Modules.Project">
    <Style TargetType="{x:Type local:SelectProjectComboBox}" BasedOn="{StaticResource {x:Static ComboBoxKeys.Default}}">
        <Setter Property="Width" Value="150"/>
        <Setter Property="DisplayMemberPath" Value="Name"/>
        <Setter Property="ItemsSource" Value="{Binding Source={x:Static IocProject.Instance}, Path=Collection}"/>
        <Setter Property="SelectedItem" Value="{Binding Source={x:Static IocProject.Instance}, Path=Current, Mode=OneWay}"/>
    </Style>
</ResourceDictionary>