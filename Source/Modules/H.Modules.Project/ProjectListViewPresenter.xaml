<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:c="clr-namespace:H.Modules.Project.Commands"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.Modules.Project"
    xmlns:p="clr-namespace:H.Modules.Project.Properties">
    <DataTemplate DataType="{x:Type local:ProjectListViewPresenter}">
        <DockPanel>
            <DockPanel Margin="2" DockPanel.Dock="Top">
                <Button
                    HorizontalAlignment="Right"
                    Command="{c:ShowNewProjectCommand AutoClose=True}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Content="{x:Static p:Resources.Type_ShowNewProjectCommand}"
                    DockPanel.Dock="Right"
                    Visibility="{Binding UseAddProject, Converter={GetTrueToVisibleConverter}}" />
                <TextBox
                    Width="Auto"
                    Margin="2"
                    Cattach.Icon="{x:Static FontIcons.Search}"
                    Style="{DynamicResource {x:Static TextBoxKeys.Delete}}" />
            </DockPanel>

            <Border BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrush}}" BorderThickness="1">
                <local:ProjectBox SelectedProject="{Binding SelectedItem, Mode=TwoWay}">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.Panel>
                                <ItemsPanelTemplate>
                                    <DataGridRowsPresenter />
                                </ItemsPanelTemplate>
                            </GroupStyle.Panel>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="{x:Type GroupItem}">
                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static h:BrushKeys.Accent}}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                                <Expander Header="{Binding Name}" IsExpanded="True">
                                                    <Expander.HeaderTemplate>
                                                        <DataTemplate>
                                                            <TextBlock
                                                                HorizontalAlignment="Left"
                                                                FontWeight="Bold"
                                                                Text="{Binding}" />
                                                        </DataTemplate>
                                                    </Expander.HeaderTemplate>
                                                    <ItemsPresenter />
                                                </Expander>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="MouseDoubleClick">
                            <b:InvokeCommandAction Command="{SumitDialogCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </local:ProjectBox>
            </Border>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>