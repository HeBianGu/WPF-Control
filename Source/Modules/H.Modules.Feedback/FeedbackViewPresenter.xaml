<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.Modules.Feedback"
    xmlns:p="clr-namespace:H.Modules.Feedback.Properties">
    <DataTemplate DataType="{x:Type local:FeedbackViewPresenter}">
        <DockPanel>
            <TextBlock
                Margin="0,5"
                HorizontalAlignment="Center"
                DockPanel.Dock="Top"
                Text="{x:Static p:Resources.Feedback_Prompt}"
                TextWrapping="Wrap" />
            <TextBlock
                Margin="0,5"
                HorizontalAlignment="Right"
                DockPanel.Dock="Bottom"
                Text="{x:Static p:Resources.Feedback_Confidentiality}"
                TextWrapping="Wrap" />


            <ItemsControl
                Margin="0,5"
                HorizontalAlignment="Right"
                DockPanel.Dock="Bottom"
                ItemsSource="{Binding Files}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="60">
                            <DockPanel>
                                <TextBlock
                                    Margin="5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Bottom"
                                    FontSize="10"
                                    Text="{Binding ., Converter={h:GetFilePathSizeToDisplayConverter}}" />
                                <Image Source="{Binding ., Converter={h:GetFilePathToSystemInfoIconConverter}}" ToolTip="{Binding}" />
                            </DockPanel>

                            <Button
                                Width="15"
                                Height="15"
                                Margin="-5"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                VerticalContentAlignment="Center"
                                Background="{DynamicResource {x:Static BrushKeys.Red}}"
                                Cattach.CornerRadius="10"
                                Content="×"
                                Foreground="White">
                                <b:Interaction.Behaviors>
                                    <h:ButtonRemoveItemBehavior />
                                </b:Interaction.Behaviors>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <Button
                HorizontalAlignment="Right"
                Command="{Binding AddFilesCommand}"
                Content="{x:Static p:Resources.Feedback_AddFiles}"
                DockPanel.Dock="Bottom" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="FeedbackColumn" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,2,0"
                    VerticalAlignment="Center"
                    Text="{x:Static p:Resources.Feedback_Name}" />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Text="{Binding Title}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,2,0"
                    VerticalAlignment="Center"
                    Text="{x:Static p:Resources.Feedback_Contact}" />
                <TextBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="{Binding Contact}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,2,0"
                    VerticalAlignment="Center"
                    Text="{x:Static p:Resources.Feedback_Quesion}" />
                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Height="Auto"
                    Margin="0,5"
                    VerticalAlignment="Stretch"
                    Text="{Binding Text}" />
            </Grid>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>