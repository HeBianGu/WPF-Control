<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.Modules.Home.Presenters">
    <DataTemplate DataType="{x:Type local:ProjectThumbnialHomeViewPresenter}">
        <DockPanel Margin="20">
            <TextBlock DockPanel.Dock="Top" FontSize="30">
                <Run Text="欢迎使用" /><Run Text="{x:Static ApplicationProvider.Product}" />
            </TextBlock>
            <Button
                Width="120"
                Margin="0,20"
                HorizontalAlignment="Left"
                Command="{Binding ShowProjectCommand}"
                DockPanel.Dock="Top"
                Style="{DynamicResource {x:Static ButtonKeys.Accent}}">
                <Button.Content>
                    <DockPanel>
                        <FontIconTextBlock FontSize="12" Text="{x:Static FontIcons.Project}" />
                        <TextBlock
                            Margin="5,0"
                            VerticalAlignment="Center"
                            Text="工程管理" />
                    </DockPanel>
                </Button.Content>
            </Button>

            <TabControl Padding="5,8" Cattach.ItemBorderThickness="1">
                <TabControl.Resources>
                    <Style BasedOn="{StaticResource {x:Static ListBoxKeys.Default}}" TargetType="ListBox">
                        <Setter Property="ItemsSource" Value="{Binding Source={x:Static IocProject.Instance}, Path=Collection}" />
                        <Setter Property="Cattach.ItemHeight" Value="Auto" />
                        <Setter Property="Margin" Value="2,0" />
                        <Setter Property="ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="ItemTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <Border>
                                        <ContentPresenter Content="{Binding ThumbnailPresenter}" />
                                    </Border>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabItem
                    Width="120"
                    Cattach.CaptionHorizontalAlignment="Center"
                    Header="最近打开">
                    <ListBox>
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="MouseDoubleClick">
                                <b:InvokeCommandAction Command="{Binding ShowOpenProjectCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=SelectedItem}" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ListBox>
                </TabItem>
                <TabItem
                    Width="120"
                    Cattach.CaptionHorizontalAlignment="Center"
                    Header="示例项目">
                    <ListBox ItemsSource="{local:GetExampleProjects}">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="MouseDoubleClick">
                                <b:InvokeCommandAction Command="{Binding ShowOpenProjectCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=SelectedItem}" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ListBox>
                </TabItem>
            </TabControl>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>