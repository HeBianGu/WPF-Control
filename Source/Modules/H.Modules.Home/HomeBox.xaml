<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:bs="clr-namespace:H.Modules.Home.Base"
    xmlns:local="clr-namespace:H.Modules.Home">

    <Style TargetType="{x:Type local:HomeBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HomeBox}">
                    <Grid>
                        <ContentPresenter x:Name="cp_home" Content="{Ioc Type={x:Type bs:IHomeViewPresenter}}" />
                        <ContentPresenter x:Name="cp_project" Content="{Binding Source={x:Static IocProject.Instance}, Path=Current.Presenter}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding ElementName=cp_project, Path=Content, Converter={x:Static Converter.GetNullToFalse}}" Value="True">
                            <Setter TargetName="cp_home" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>