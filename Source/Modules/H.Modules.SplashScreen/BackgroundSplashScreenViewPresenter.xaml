<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:H.Modules.SplashScreen">
    <DataTemplate DataType="{x:Type local:BackgroundSplashScreenViewPresenter}">
        <Grid
            Width="900"
            Height="450"
            TextBlock.Foreground="White">
            <Grid Margin="50">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Viewbox Width="300" DockPanel.Dock="Bottom">
                        <Grid>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=SubFontSize}"
                                Opacity="0.6"
                                Text="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=Sub}" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=SubFontSize}"
                                Opacity="0.35"
                                RenderTransformOrigin="0 1"
                                Text="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=Sub}">
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleY="-0.5" />
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                                <TextBlock.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#70FFFFFF" />
                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                    </LinearGradientBrush>
                                </TextBlock.OpacityMask>
                                <TextBlock.Effect>
                                    <BlurEffect Radius="0.6" />
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>
                    </Viewbox>
                    <Viewbox Margin="10">
                        <Grid>
                            <TextBlock HorizontalAlignment="Center" Text="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=Product}" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                Opacity="0.65"
                                RenderTransformOrigin="0 1"
                                Text="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=Product}">
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleY="-0.5" />
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                                <TextBlock.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#70FFFFFF" />
                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                    </LinearGradientBrush>
                                </TextBlock.OpacityMask>
                                <TextBlock.Effect>
                                    <BlurEffect Radius="0.6" />
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>
                    </Viewbox>
                </DockPanel>

                <TextBlock
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{DynamicResource {x:Static FontSizeKeys.Header3}}"
                    Text="{Binding Message}" />
                <TextBlock
                    Grid.Row="2"
                    Margin="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{DynamicResource {x:Static FontSizeKeys.Header5}}"
                    Text="{x:Static ApplicationProvider.Copyright}" />
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>