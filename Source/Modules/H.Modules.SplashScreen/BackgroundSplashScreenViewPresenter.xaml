<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:H.Modules.SplashScreen">
    <DataTemplate DataType="{x:Type local:BackgroundSplashScreenViewPresenter}">
        <Grid Width="900"
              Height="450"
              TextBlock.Foreground="White">
            <Grid Margin="50">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <Viewbox Width="300"
                             DockPanel.Dock="Bottom">
                        <TextBlock HorizontalAlignment="Center"
                                   DockPanel.Dock="Bottom"
                                   FontSize="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=SubFontSize}"
                                   Opacity="0.8"
                                   Text="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=Sub}" />
                    </Viewbox>
                    <Viewbox Margin="10">
                        <TextBlock Text="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=Product}" />
                    </Viewbox>
                </DockPanel>

                <TextBlock Grid.Row="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource {x:Static FontSizeKeys.Header3}}"
                           Text="{Binding Message}" />
                <TextBlock Grid.Row="2"
                           Margin="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource {x:Static FontSizeKeys.Header5}}"
                           Text="{x:Static ApplicationProvider.Copyright}" />
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>