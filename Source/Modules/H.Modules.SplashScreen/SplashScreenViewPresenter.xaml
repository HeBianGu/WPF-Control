<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:H.Modules.SplashScreen">
    <DataTemplate DataType="{x:Type local:SplashScreenViewPresenter}">
        <Grid Width="550"
              Height="280">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               DockPanel.Dock="Bottom"
                               FontSize="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=SubFontSize}"
                               Opacity="0.8"
                               Text="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=Sub}" />

                    <Viewbox Margin="0,10">
                        <TextBlock Text="{Binding Source={x:Static local:SplashScreenOptions.Instance}, Path=Product}" />
                    </Viewbox>
                </DockPanel>

                <TextBlock Grid.Row="1"
                           Margin="0,10"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource {x:Static FontSizeKeys.Header4}}"
                           Text="{Binding Message}" />

                <TextBlock Grid.Row="2"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource {x:Static FontSizeKeys.Header6}}"
                           Text="{x:Static ApplicationProvider.Copyright}" />
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>