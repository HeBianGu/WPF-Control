<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:p="clr-namespace:H.Modules.Identity.Properties"
    xmlns:local="clr-namespace:H.Modules.Identity">

    <DataTemplate DataType="{x:Type local:AuthorityViewPresenter}">
        <DockPanel
            MinWidth="900"
            IsEnabled="{Binding IsEnabled}"
            Visibility="{Binding IsVisible, Converter={x:Static h:Converter.GetTrueToVisible}}">
            <RepositoryGrid
                AutoGenerateColumns="False"
                Type="{x:Type local:hi_dd_author}"
                UseAdd="False"
                UseDelete="False"
                UseEdit="False">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Loaded">
                        <b:InvokeCommandAction Command="{Binding LoadedCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
                <h:Cattach.CaptionRightTemplate>
                    <ControlTemplate>
                        <h:TextFilterBox
                            x:Name="tfb1"
                            Width="200"
                            Margin="0,5"
                            DockPanel.Dock="Top">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="FilterChanged">
                                    <b:ChangePropertyAction
                                        PropertyName="Filter1"
                                        TargetObject="{Binding Collection}"
                                        Value="{Binding ElementName=tfb1, Path=Filter}" />
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </h:TextFilterBox>
                    </ControlTemplate>
                </h:Cattach.CaptionRightTemplate>
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding Model.ID}"
                        Header="{x:Static p:Resources.ID}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Model.Name}"
                        Header="{x:Static p:Resources.AuthorName}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Model.Code}"
                        Header="{x:Static p:Resources.AuthorCode}" />
                    <DataGridTemplateColumn Width="*" Header="{x:Static p:Resources.Roles}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding Model.Roles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,5" Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="*" Header="{x:Static p:Resources.Users}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding Model.Roles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ItemsControl ItemsSource="{Binding Users}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Margin="0,5" Text="{Binding Name}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </RepositoryGrid>
        </DockPanel>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsAuthority}" Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
</ResourceDictionary>