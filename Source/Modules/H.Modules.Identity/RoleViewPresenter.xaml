<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:p="clr-namespace:H.Modules.Identity.Properties"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.Modules.Identity">
    <DataTemplate DataType="{x:Type local:RoleViewPresenter}">
        <DockPanel
            MinWidth="900"
            IsEnabled="{Binding IsEnabled}"
            Visibility="{Binding IsVisible, Converter={x:Static h:Converter.GetTrueToVisible}}">
            <RepositoryGrid AutoGenerateColumns="False" Type="{x:Type local:hi_dd_role}">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Loaded">
                        <b:InvokeCommandAction Command="{Binding LoadedCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding Model.ID}"
                        Header="{x:Static p:Resources.ID}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Model.Name}"
                        Header="{x:Static p:Resources.RoleName}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Model.Code}"
                        Header="{x:Static p:Resources.RoleCode}" />
                    <DataGridTemplateColumn Width="*" Header="{x:Static p:Resources.Users}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding Model.Users}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,5" Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="*" Header="{x:Static p:Resources.Authors}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding Model.Authors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,5" Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <h:Cattach.CaptionRightTemplate>
                    <ControlTemplate>
                        <TextFilterBox
                                x:Name="tfb1"
                                Width="200"
                                DockPanel.Dock="Top">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="FilterChanged">
                                    <b:ChangePropertyAction
                                            PropertyName="Filter1"
                                            TargetObject="{Binding Collection}"
                                            Value="{Binding ElementName=tfb1, Path=Filter}" />
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </TextFilterBox>
                    </ControlTemplate>
                </h:Cattach.CaptionRightTemplate>
            </RepositoryGrid>
        </DockPanel>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsAuthority}" Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:RoleEditPresenter}">
        <DockPanel MinWidth="300">
            <BulletDecorator Margin="0,5" DockPanel.Dock="Top">
                <BulletDecorator.Bullet>
                    <TextBlock Text="{x:Static p:Resources.RoleName}" />
                </BulletDecorator.Bullet>
                <TextBox Margin="5,0,0,0" Text="{Binding Model.Name}" />
            </BulletDecorator>
            <ListBox ItemsSource="{Binding Authors}" SelectionMode="Multiple">
                <b:Interaction.Behaviors>
                    <h:ListBoxBindingSelectedItemsBehavior SelectedItems="{Binding Model.Authors}" />
                </b:Interaction.Behaviors>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ListBox>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>