<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:l="clr-namespace:H.Presenters.Design"
    xmlns:local="clr-namespace:H.Presenters.Design.Controls">
    <Style
        x:Key="{ComponentResourceKey ResourceId=S.Border.Binding,
                                     TypeInTargetAssembly={x:Type local:DesignBorderKeys}}"
        BasedOn="{StaticResource {x:Static DesignPresenterKeys.BindBorder}}"
        TargetType="{x:Type Border}">
        <Setter Property="SelectedHitTestAdornerBehavior.IsSelected" Value="{Binding IsSelected}" />
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu>
                    <MenuItem
                        Command="{Binding DeleteCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                        Header="删除" />
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsEnabled}" Value="false">
                <Setter Property="Opacity" Value="0.6" />
            </DataTrigger>
        </Style.Triggers>
    </Style>


    <ControlTemplate x:Key="S.ControlTemplate.Adorner" TargetType="ContentControl">
        <DockPanel
            Margin="-15"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top">
            <!--<TextBlock Foreground="{DynamicResource {x:Static h:BrushKeys.Accent}}" Style="{DynamicResource {x:Static h:TextBlockKeys.Icon}}" Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.Icon}" />
            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource {x:Static h:BrushKeys.Accent}}">
                <Run Text="[" />
                <Run Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.Name}" />
                <Run Text="]" />
            </TextBlock>-->
            <ItemsControl
                DockPanel.Dock="Right"
                IsEnabled="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.Locked, Converter={GetTrueToFalseValueConverter}}"
                ItemsSource="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.Commands}"
                Visibility="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.UseTool, Converter={GetTrueToVisibleConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <FontIconButton
                            x:Name="b"
                            Margin="1,0"
                            Background="{DynamicResource {x:Static BrushKeys.Background}}"
                            BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrush}}"
                            BorderThickness="1"
                            Cattach.CornerRadius="50"
                            Command="{Binding}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContentControl}}"
                            Style="{DynamicResource {x:Static FontIconButtonKeys.Command}}" />
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Name}" Value="删除">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource {x:Static BrushKeys.Red}}" />
                                <Setter TargetName="b" Property="Foreground" Value="White" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <FontIconToggleButton
                Margin="1,0"
                BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrush}}"
                Cattach.CornerRadius="50"
                CheckedGlyph="{x:Static FontIcons.Lock}"
                DockPanel.Dock="Right"
                IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ContentControl}, Path=Content.Locked, Mode=TwoWay}"
                UncheckedGlyph="{x:Static FontIcons.Unlock}"
                Visibility="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.UseTool, Converter={GetTrueToVisibleConverter}}">
                <FontIconToggleButton.Style>
                    <Style BasedOn="{StaticResource {x:Static FontIconToggleButtonKeys.Switch}}" TargetType="{x:Type FontIconToggleButton}">
                        <Setter Property="Background" Value="{DynamicResource {x:Static BrushKeys.Background}}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static BrushKeys.Orange}}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </FontIconToggleButton.Style>
            </FontIconToggleButton>
            <!--<DockPanel DockPanel.Dock="Right">
                <FontIconButton
                    Background="{DynamicResource {x:Static BrushKeys.Red}}"
                    BorderBrush="Transparent"
                    Cattach.CornerRadius="50"
                    Command="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.DeleteCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}}"
                    Content="{x:Static FontIcons.Delete}"
                    Foreground="White"
                    IsEnabled="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.Locked, Converter={GetTrueToFalseValueConverter}}"
                    ToolTip="删除" />
            </DockPanel>-->

            <!--<Button h:Cattach.Icon="&#xe729;"
                    h:Cattach.IconSize="20"
                    Background="Gray"
                    BorderBrush="Transparent"
                    DockPanel.Dock="Right"
                    Foreground="White"
                    Content="{x:Static h:Geometrys.Close}"
                    Style="{DynamicResource {x:Static h:ButtonKeys.Geometry}}"
                    ToolTip="另存为模板" />-->

            <!--<TextBlock Foreground="{DynamicResource {x:Static h:BrushKeys.Accent}}"
                       Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.Icon}" />-->

            <TextBlock
                VerticalAlignment="Center"
                FontSize="18"
                Foreground="{DynamicResource {x:Static h:BrushKeys.Accent}}">
                <Run Text="[" /><Run Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.Name}" /> <Run Text="]" />
            </TextBlock>
            <!--<Button h:Cattach.Icon="{x:Static h:Icons.User}"
                    Background="LightGray"
                    Foreground="Black"
                    Style="{DynamicResource {x:Static h:ButtonKeys.MouseOver}}" />-->

            <!--<h:PropertyGrid Width="100"
                                    Height="30"
                                    Background="Red"
                                    SelectObject="{Binding}"
                                    Style="{DynamicResource {x:Static h:PropertyGrid.DefaultKey}}"
                                    UseAsync="False"
                                    UseCommand="True"
                                    UseString="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <DockPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </h:PropertyGrid>-->
        </DockPanel>
    </ControlTemplate>

    <Style
        x:Key="{ComponentResourceKey ResourceId=S.DesignBorder.Default,
                                     TypeInTargetAssembly={x:Type local:DesignBorder}}"
        BasedOn="{StaticResource {x:Static local:DesignBorderKeys.Binding}}"
        TargetType="{x:Type local:DesignBorder}">
        <Setter Property="AllowDrop" Value="False" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="MouseOverHitTestAdornerBehavior.IsMouseOver" Value="{Binding IsMouseOver, Mode=TwoWay}" />
        <Setter Property="SelectedHitTestAdornerBehavior.IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
        <Setter Property="HitTestAdornerBehavior.IsHitTest" Value="True" />
        <Setter Property="BehvaiorAttach.Behaviors">
            <Setter.Value>
                <Behaviors>
                    <DraggableDataTemplateAdornerBehavior DragDropEffects="Move" RoutingStrategy="Tunnel" />
                </Behaviors>
            </Setter.Value>
        </Setter>
        <Setter Property="ControlTemplateAdorner.Template" Value="{StaticResource S.ControlTemplate.Adorner}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding BorderBrush}" Value="{x:Null}">
                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static BrushKeys.BorderBrush}}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=l:DesignBox}, Path=UseDesign, FallbackValue=false}" Value="false">
                <Setter Property="IsHitTestVisible" Value="True" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style BasedOn="{StaticResource {x:Static local:DesignBorder.DefaultKey}}" TargetType="{x:Type local:DesignBorder}" />
</ResourceDictionary>