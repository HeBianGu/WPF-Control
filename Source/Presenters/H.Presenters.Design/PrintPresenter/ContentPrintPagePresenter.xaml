<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:H.Presenters.Design.PrintPresenter"
    xmlns:lp="clr-namespace:H.Presenters.Design.Presenter">
    <DataTemplate DataType="{x:Type local:ContentPrintPagePresenter}">
        <lp:DesignBorder MinWidth="200" MinHeight="400">
            <ContentPresenter Content="{Binding Content}" />
        </lp:DesignBorder>
    </DataTemplate>
</ResourceDictionary>