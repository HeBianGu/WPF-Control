<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:H.Presenters.Design.Controls"
    xmlns:local="clr-namespace:H.Presenters.Design.PrintPresenter">
    <DataTemplate DataType="{x:Type local:DefinitionGridPrintPagePresenter}">
        <c:DesignBorder MinWidth="200" MinHeight="400">
            <ContentPresenter Content="{Binding Content}" />
        </c:DesignBorder>
    </DataTemplate>
</ResourceDictionary>