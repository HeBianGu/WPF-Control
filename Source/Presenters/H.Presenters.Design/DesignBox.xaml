<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:H.Presenters.Design">
    <Style
        x:Key="{ComponentResourceKey ResourceId=S.DesignBox.Default,
                                     TypeInTargetAssembly={x:Type local:DesignBox}}"
        BasedOn="{StaticResource {x:Type ContentControl}}"
        TargetType="{x:Type local:DesignBox}" />
    <Style BasedOn="{StaticResource {x:Static local:DesignBox.DefaultKey}}" TargetType="{x:Type local:DesignBox}" />
</ResourceDictionary>