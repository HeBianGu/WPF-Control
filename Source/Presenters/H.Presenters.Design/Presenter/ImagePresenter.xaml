<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:H.Presenters.Design.Controls"
    xmlns:local="clr-namespace:H.Presenters.Design.Presenter"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <DataTemplate DataType="{x:Type local:ImagePresenter}">
        <c:DesignBorder>
            <Image Source="{Binding ImageSource}" Stretch="{Binding Stretch}" />
        </c:DesignBorder>
    </DataTemplate>
</ResourceDictionary>