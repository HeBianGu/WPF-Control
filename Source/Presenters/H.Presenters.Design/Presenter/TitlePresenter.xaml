<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:H.Presenters.Design.Controls"
    xmlns:local="clr-namespace:H.Presenters.Design.Presenter"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <DataTemplate DataType="{x:Type local:TitlePresenter}">
        <c:DesignBorder>
            <DockPanel VerticalAlignment="{Binding VerticalContentAlignment}">
                <TextBlock
                    Height="Auto"
                    FontSize="{Binding TitleFontSize}"
                    FontWeight="{Binding TitleFontWeight}"
                    Style="{DynamicResource {x:Static DesignTextBlockKeys.Binding}}"
                    Text="{Binding Title}" />
                <TextBlock
                    Height="Auto"
                    Style="{DynamicResource {x:Static DesignTextBlockKeys.Binding}}"
                    Text="{Binding Text}" />
            </DockPanel>
        </c:DesignBorder>
    </DataTemplate>
</ResourceDictionary>