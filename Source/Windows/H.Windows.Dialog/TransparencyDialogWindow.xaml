<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.Windows.Dialog">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/H.Windows.Dialog;component/DialogWindow.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <Style
        x:Key="{ComponentResourceKey ResourceId=S.TransparencyDialogWindow.Default,
                                     TypeInTargetAssembly={x:Type local:TransparencyDialogKeys}}"
        BasedOn="{StaticResource {x:Static local:DialogKeys.Default}}"
        TargetType="{x:Type local:TransparencyDialogWindow}">
        <Setter Property="AllowsTransparency" Value="True" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TransparencyDialogWindow}">
                    <Grid>
                        <Border
                            Margin="20"
                            Background="{DynamicResource {x:Static BrushKeys.Background}}"
                            BorderBrush="{DynamicResource {x:Static BrushKeys.BorderBrush}}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource {x:Static LayoutKeys.CornerRadius}}"
                            Effect="{DynamicResource {x:Static DropShadowEffectKeys.Window}}" />
                        <Border Margin="19">
                            <Border
                                Margin="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(Cattach.CornerRadius)}">
                                <Grid x:Name="grid">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border
                                        Grid.Row="0"
                                        Margin="0"
                                        Background="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=(h:Cattach.CaptionBackground)}"
                                        CornerRadius="2 2 0 0"
                                        TextBlock.Foreground="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(Cattach.CaptionForeground)}"
                                        TextElement.Foreground="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=(h:Cattach.CaptionForeground)}">
                                        <Grid Margin="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(Cattach.CaptionMargin)}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel
                                                Margin="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(Cattach.TitleMargin)}"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <FontIconButton
                                                    VerticalAlignment="Center"
                                                    Command="{x:Static SystemCommands.ShowSystemMenuCommand}"
                                                    Content="{TemplateBinding FontIcon}"
                                                    IsTabStop="False"
                                                    Foreground="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=(Cattach.CaptionForeground)}"
                                                    Visibility="{Binding FontIcon, RelativeSource={RelativeSource Mode=TemplatedParent}, Converter={x:Static Converter.GetNullToCollapsed}}"
                                                    WindowChrome.IsHitTestVisibleInChrome="True" />
                                                <TextBlock VerticalAlignment="Center" Text="{TemplateBinding Title}" />
                                            </StackPanel>

                                            <StackPanel
                                                Grid.Column="1"
                                                Margin="0"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal">
                                                <FontIconButton
                                                    Command="{MinimizeWindowCommand}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                    Content="{x:Static FontIcons.ChromeMinimize}"
                                                    Foreground="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=(Cattach.CaptionForeground)}"
                                                    Style="{DynamicResource {x:Static h:WindowKeys.MinimizeButton}}" />
                                                <FontIconButton
                                                    Command="{MaximizeWindowCommand}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                    Content="{x:Static FontIcons.ChromeMaximize}"
                                                    Foreground="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=(Cattach.CaptionForeground)}"
                                                    Style="{DynamicResource {x:Static h:WindowKeys.MaximizeButton}}" />
                                                <FontIconButton
                                                    Command="{RestoreWindowCommand}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                    Content="{x:Static FontIcons.ChromeRestore}"
                                                    Foreground="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=(Cattach.CaptionForeground)}"
                                                    Style="{DynamicResource {x:Static h:WindowKeys.RestoreButton}}" />
                                                <FontIconButton
                                                    Command="{CloseWindowCommand}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                    Content="{x:Static FontIcons.ChromeClose}"
                                                    Foreground="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=(Cattach.CaptionForeground)}"
                                                    IsCancel="True"
                                                    Style="{DynamicResource {x:Static h:WindowKeys.CloseButton}}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <AdornerDecorator Grid.Row="1" Grid.ColumnSpan="3">
                                        <ContentPresenter
                                            Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    </AdornerDecorator>
                                    <Control Grid.Row="2" Template="{TemplateBinding BottomTemplate}" />
                                </Grid>
                            </Border>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsActive" Value="False">
                            <Setter TargetName="grid" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="BottomTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <Button
                        Width="100"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        Command="{local:SumitWindowCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="确定" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{ComponentResourceKey ResourceId=S.TransparencyDialogWindow.None, TypeInTargetAssembly={x:Type local:TransparencyDialogKeys}}" TargetType="{x:Type local:DialogWindow}">
        <Setter Property="BottomTemplate" Value="{x:Null}" />
    </Style>
    <Style x:Key="{ComponentResourceKey ResourceId=S.TransparencyDialogWindow.Sumit, TypeInTargetAssembly={x:Type local:TransparencyDialogKeys}}" TargetType="{x:Type local:DialogWindow}">
        <Setter Property="BottomTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <Button
                        Width="100"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        Command="{local:SumitWindowCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="确定"
                        IsDefault="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{ComponentResourceKey ResourceId=S.TransparencyDialogWindow.Cancel, TypeInTargetAssembly={x:Type local:TransparencyDialogKeys}}" TargetType="{x:Type local:DialogWindow}">
        <Setter Property="BottomTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <Button
                        Width="100"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        Command="{x:Static SystemCommands.CloseWindowCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="取消"
                        IsCancel="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{ComponentResourceKey ResourceId=S.TransparencyDialogWindow.SumitAndCancel, TypeInTargetAssembly={x:Type local:TransparencyDialogKeys}}" TargetType="{x:Type local:DialogWindow}">
        <Setter Property="BottomTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Button
                            Width="100"
                            Margin="6,0,6,10"
                            HorizontalAlignment="Center"
                            Command="{local:SumitWindowCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="确定"
                            IsDefault="True" />
                        <Button
                            Width="100"
                            Margin="6,0,6,10"
                            HorizontalAlignment="Center"
                            Command="{x:Static SystemCommands.CloseWindowCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="取消"
                            IsCancel="True" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style BasedOn="{StaticResource {x:Static local:TransparencyDialogKeys.Default}}" TargetType="{x:Type local:TransparencyDialogWindow}" />
</ResourceDictionary>