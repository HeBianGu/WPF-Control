<Window
    x:Class="H.Test.Design.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:local="clr-namespace:H.Test.Design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    Style="{StaticResource {x:Static WindowKeys.Default}}"
    mc:Ignorable="d">
    <DockPanel>
        <ScrollViewer>
            <ListBox Width="250" ItemsSource="{GetDesignPresenters}">
                <!--<h:CardPresenter />
       <h:TextBlockPresenter Text="测试" />-->
            </ListBox>
        </ScrollViewer>
        <Grid>
            <DesignBox>
                <h:FixedGridPresenter Columns="5" Rows="5" />
            </DesignBox>
        </Grid>
    </DockPanel>
</Window>
