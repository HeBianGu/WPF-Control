<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.Components.Vision.Presenters">
    <DataTemplate DataType="{x:Type local:VisionDiagramPreseter}">
        <DockPanel>
            <GroupBox Width="300" Header="流程资源列表">
                <ContentPresenter Content="{Binding DiagramData.NodeGroups, Converter={GetNodeDataGroupsItemsControlPresenter}}" Visibility="{Binding RelativeSource={RelativeSource AncestorType=GroupBox}}" />
            </GroupBox>
            <GroupBox
                Width="400"
                DockPanel.Dock="Right"
                Header="属性栏">
                <DockPanel>
                    <Border
                        Height="300"
                        DockPanel.Dock="Top"
                        Style="{DynamicResource {x:Static BorderKeys.BorderBrush}}">
                        <ContentPresenter Content="{Binding DiagramData.SelectedPartData, Converter={local:GetVisionNodeDataImageViewPreseterValueConverter}}" />
                    </Border>
                    <TabControl
                        BorderThickness="1"
                        ItemContainerStyle="{DynamicResource {x:Static TabItemKeys.Line}}"
                        TabStripPlacement="Top">
                        <TabItem
                            Width="73"
                            Cattach.CaptionHorizontalAlignment="Center"
                            Header="{x:Static VisionPropertyGroupNames.RunParameters}">
                            <Form
                                Margin="5"
                                SelectObject="{Binding DiagramData.SelectedPartData}"
                                UseGroupNames="{x:Static VisionPropertyGroupNames.RunParameters}" />
                        </TabItem>
                        <TabItem
                            Width="73"
                            Cattach.CaptionHorizontalAlignment="Center"
                            Header="{x:Static VisionPropertyGroupNames.ResultParameters}">
                            <Form
                                Margin="5"
                                SelectObject="{Binding DiagramData.SelectedPartData}"
                                UseGroupNames="{x:Static VisionPropertyGroupNames.ResultParameters}" />
                        </TabItem>
                        <TabItem
                            Width="73"
                            Cattach.CaptionHorizontalAlignment="Center"
                            Header="{x:Static VisionPropertyGroupNames.BaseParameters}">
                            <Form
                                Margin="5"
                                SelectObject="{Binding DiagramData.SelectedPartData}"
                                UseGroupNames="{x:Static VisionPropertyGroupNames.BaseParameters}" />
                        </TabItem>
                        <TabItem
                            Width="73"
                            Cattach.CaptionHorizontalAlignment="Center"
                            Header="{x:Static VisionPropertyGroupNames.DisplayParameters}">
                            <Form
                                Margin="5"
                                SelectObject="{Binding DiagramData.SelectedPartData}"
                                UseGroupNames="{x:Static VisionPropertyGroupNames.DisplayParameters}" />
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </GroupBox>
            <GroupBox Margin="2,0" Header="流程图">
                <Grid>
                    <Zoombox
                        DragModifiers=""
                        Focusable="True"
                        IsTabStop="True"
                        MinScale="0.2"
                        NavigateOnPreview="False"
                        RelativeZoomModifiers=""
                        ViewStackIndex="0"
                        ZoomOn="Content">
                        <Zoombox.ViewStack>
                            <ZoomboxView>250 500 500 500</ZoomboxView>
                        </Zoombox.ViewStack>
                        <ContentPresenter Content="{Binding DiagramData}" />
                    </Zoombox>
                    <Border
                        Margin="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom">
                        <Border.Background>
                            <SolidColorBrush Opacity="0.2" Color="Black" />
                        </Border.Background>
                        <TextBlock VerticalAlignment="Bottom" Text="{Binding DiagramData.Message}" />
                    </Border>

                    <DockPanel>
                        <DockPanel.Resources>
                            <Style TargetType="ItemsControl">
                                <Setter Property="ItemsPanel">
                                    <Setter.Value>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical" />
                                        </ItemsPanelTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ItemTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <FontIconButton Command="{Binding}" Style="{DynamicResource {x:Static FontIconButtonKeys.Command}}" />
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DockPanel.Resources>

                        <Border
                            Margin="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            DockPanel.Dock="Top">
                            <Border.Background>
                                <SolidColorBrush Opacity="0.2" Color="Black" />
                            </Border.Background>
                            <ItemsControl ItemsSource="{Binding DiagramData.Commands, Converter={GetGroupCommandsValueConverter GroupName=流程控制}}" />
                        </Border>

                        <Border
                            Margin="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            DockPanel.Dock="Top">
                            <Border.Background>
                                <SolidColorBrush Opacity="0.2" Color="Black" />
                            </Border.Background>
                            <ItemsControl ItemsSource="{Binding DiagramData.Commands, Converter={GetGroupCommandsValueConverter GroupName=数据}}" />

                        </Border>

                        <Border
                            Margin="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            DockPanel.Dock="Top">
                            <Border.Background>
                                <SolidColorBrush Opacity="0.2" Color="Black" />
                            </Border.Background>
                            <ItemsControl ItemsSource="{Binding DiagramData.Commands, Converter={GetGroupCommandsValueConverter GroupName=视图控制}}" />
                        </Border>
                    </DockPanel>
                </Grid>
            </GroupBox>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>