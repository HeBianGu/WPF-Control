<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.Components.Vision.Presenters">
    <DataTemplate DataType="{x:Type local:ShapeViewPropertyItem}">
        <Border Height="200" MinWidth="200">
            <Grid>
                <ShapeZoomBox x:Name="zoomview1" Shapes="{Binding Shapes, IsAsync=True}">
                    <b:Interaction.Behaviors>
                        <ZoomBoxFitOnLoadedBehavior />
                        <ZoomBoxFitOnSizeChangedBehavior />
                    </b:Interaction.Behaviors>
                    <ShapeZoomBox.ViewStack>
                        <ZoomboxView>Fit</ZoomboxView>
                    </ShapeZoomBox.ViewStack>
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="MouseDoubleClick">
                            <CallMethodActionEx MethodName="ZoomToShapes" TargetObject="{Binding ElementName=zoomview1}" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                    <ShapeBox
                        x:Name="imageBox"
                        MinWidth="100"
                        MinHeight="100"
                        ImagePixelHeight="2000"
                        ImagePixelWidth="2000"
                        Scale="{Binding ElementName=zoomview1, Path=Scale}"
                        Shapes="{Binding Shapes}"
                        Stroke="{Binding Source={x:Static ShapeViewSetting.Instance}, Path=Stroke}"
                        StrokeThickness="{Binding Source={x:Static ShapeViewSetting.Instance}, Path=StrokeThickness}" />
                </ShapeZoomBox>
                <Border
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    CornerRadius="2">
                    <Border.Background>
                        <SolidColorBrush Opacity="0.5" Color="{DynamicResource {x:Static ColorKeys.Background}}" />
                    </Border.Background>
                    <ItemsControl ItemsSource="{Binding Commands}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <FontIconButton Command="{Binding}" Style="{DynamicResource {x:Static FontIconButtonKeys.Command}}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>