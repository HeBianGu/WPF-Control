<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:lb="clr-namespace:H.Components.Vision.Base"
    xmlns:local="clr-namespace:H.Components.Vision">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/H.Components.Vision;component/Presenters/VisionResultImage.xaml" />
        <ResourceDictionary Source="pack://application:,,,/H.Components.Vision;component/Presenters/HelpPresenter.xaml" />
        <ResourceDictionary Source="pack://application:,,,/H.Components.Vision;component/Presenters/StyleNodeData.xaml" />
        <ResourceDictionary Source="pack://application:,,,/H.Components.Vision;component/Presenters/ShapeViewPropertyItem.xaml" />
        <ResourceDictionary Source="pack://application:,,,/H.Components.Vision;component/Presenters/VisionDiagramPreseter.xaml" />
        <ResourceDictionary Source="pack://application:,,,/H.Components.Vision;component/Presenters/VisionNodeDataImageViewPreseter.xaml" />
        <!--  ResultPresenters  -->
        <ResourceDictionary Source="pack://application:,,,/H.Components.Vision;component/Presenters/ResultPresenters/DataGridResultPresenter.xaml" />
        <ResourceDictionary Source="pack://application:,,,/H.Components.Vision;component/Presenters/ResultPresenters/ValueResultPresenter.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate DataType="{x:Type local:DetectDisplayMode}">
        <TextBlock x:Name="t" />
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding}" Value="Default">
                <Setter TargetName="t" Property="Text" Value="轮廓" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Dimension">
                <Setter TargetName="t" Property="Text" Value="标尺" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Pixel">
                <Setter TargetName="t" Property="Text" Value="像素" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="RotatedRect">
                <Setter TargetName="t" Property="Text" Value="最小外接矩形" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>
