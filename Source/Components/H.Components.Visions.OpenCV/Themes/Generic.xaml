<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:dt="clr-namespace:H.Components.Visions.OpenCV.NodeDatas.Detector"
    xmlns:h="https://github.com/HeBianGu"
    xmlns:lb="clr-namespace:H.Components.Visions.OpenCV.Base"
    xmlns:ldb="clr-namespace:H.Components.Visions.OpenCV.NodeDatas.Detector"
    xmlns:local="clr-namespace:H.Components.Visions.OpenCV">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/H.Components.Visions.OpenCV;component/Presenters/TemplateManagerPresenter.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <DataTemplate DataType="{x:Type ldb:LineSearchType}">
        <TextBlock x:Name="t" />
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding}" Value="All">
                <Setter TargetName="t" Property="Text" Value="保留检测到的所有线段" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="MinLength">
                <Setter TargetName="t" Property="Text" Value="从检测到的线段中选择长度最小的线段" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="MaxLength">
                <Setter TargetName="t" Property="Text" Value="从检测到的线段中选择长度最大的线段" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Caliper">
                <Setter TargetName="t" Property="Text" Value="按卡尺区域筛选线段" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>


    <DataTemplate DataType="{x:Type ldb:PointSearchType}">
        <TextBlock x:Name="t" />
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding}" Value="All">
                <Setter TargetName="t" Property="Text" Value="保留检测到的所有" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Caliper">
                <Setter TargetName="t" Property="Text" Value="按卡尺区域筛选" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type ldb:CircleSearchType}">
        <TextBlock x:Name="t" />
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding}" Value="All">
                <Setter TargetName="t" Property="Text" Value="保留检测到的所有圆" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="MinRadius">
                <Setter TargetName="t" Property="Text" Value="从检测到的圆中选择半径最小的圆" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="MaxRadius">
                <Setter TargetName="t" Property="Text" Value="从检测到的圆中选择半径最大的圆" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Caliper">
                <Setter TargetName="t" Property="Text" Value="按卡尺区域筛选圆" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>


    <DataTemplate DataType="{x:Type ldb:BlobType}">
        <TextBlock x:Name="t" />
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding}" Value="None">
                <Setter TargetName="t" Property="Text" Value="自定义参数识别" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Circle">
                <Setter TargetName="t" Property="Text" Value="圆形识别" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Oval">
                <Setter TargetName="t" Property="Text" Value="椭圆识别" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:MatImage}">
        <DockPanel Margin="0,1">
            <Image
                Width="50"
                HorizontalAlignment="Left"
                RenderOptions.BitmapScalingMode="LowQuality"
                Source="{Binding ImageSource}" />
            <TextBlock
                Margin="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Text="{Binding Mat}"
                TextWrapping="Wrap" />
            <b:Interaction.Triggers>
                <MouseTrigger ClickCount="2">
                    <b:InvokeCommandAction Command="{ShowZoomViewImageSourceCommand}" CommandParameter="{Binding ImageSource}" />
                </MouseTrigger>
            </b:Interaction.Triggers>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>
