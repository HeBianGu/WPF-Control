<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:H.Components.Visions.OpenCV.Presenters">
    <DataTemplate DataType="{x:Type local:TemplateManagerPresenterBase}">
        <DockPanel>
            <DockPanel DockPanel.Dock="Top">
                <BulletDecorator>
                    <BulletDecorator.Bullet>
                        <TextBlock Text="选择图像：" />
                    </BulletDecorator.Bullet>
                    <ComboBox
                        MinWidth="200"
                        DisplayMemberPath="Text"
                        ItemsSource="{Binding ResultImageSourceNodeDatas}"
                        SelectedItem="{Binding SelectedImageSourceNodeData, Mode=TwoWay}" />
                </BulletDecorator>
                <ItemsControl
                    HorizontalAlignment="Left"
                    DockPanel.Dock="Top"
                    ItemsSource="{Binding Commands}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <DockPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Margin="0,0,2,0"
                                Command="{Binding}"
                                Content="{Binding Name}"
                                Style="{DynamicResource {x:Static ButtonKeys.Command}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <DockPanel
                Width="200"
                Margin="1"
                VerticalAlignment="Stretch"
                DockPanel.Dock="Right">
                <GroupBox
                    Height="200"
                    Margin="1"
                    DockPanel.Dock="Top"
                    Header="图像结果">
                    <ShapeZoomBox x:Name="zoomview2" Shapes="{Binding Shapes, IsAsync=True}">
                        <b:Interaction.Behaviors>
                            <ZoomBoxFitOnLoadedBehavior />
                            <ZoomBoxFitOnSizeChangedBehavior />
                        </b:Interaction.Behaviors>
                        <ShapeZoomBox.ViewStack>
                            <ZoomboxView>Fit</ZoomboxView>
                        </ShapeZoomBox.ViewStack>
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="MouseDoubleClick">
                                <CallMethodActionEx MethodName="ZoomToShapes" TargetObject="{Binding ElementName=zoomview2}" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                        <ShapeBox
                            MinWidth="100"
                            MinHeight="100"
                            ImagePixelHeight="2000"
                            ImagePixelWidth="2000"
                            Scale="{Binding ElementName=zoomview2, Path=Scale}"
                            Shapes="{Binding Shapes}"
                            Stroke="{Binding Source={x:Static ShapeViewSetting.Instance}, Path=Stroke}"
                            StrokeThickness="{Binding Source={x:Static ShapeViewSetting.Instance}, Path=StrokeThickness}" />
                    </ShapeZoomBox>
                </GroupBox>
                <Form
                    SelectObject="{Binding}"
                    TitleWidth="Auto"
                    UseCommand="False" />
            </DockPanel>
            <GroupBox Margin="1" Header="图像数据">
                <Grid>
                    <Zoombox
                        x:Name="zoomview1"
                        Background="{DynamicResource {x:Static BrushKeys.Tile25}}"
                        DragModifiers=""
                        Focusable="True"
                        IsTabStop="True"
                        MinScale="0.1"
                        NavigateOnPreview="False"
                        RelativeZoomModifiers=""
                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                        Tag="Image"
                        ViewStackIndex="0"
                        ZoomOn="Content">
                        <b:Interaction.Behaviors>
                            <ZoomBoxFitOnLoadedBehavior />
                            <ZoomBoxFitOnSizeChangedBehavior />
                        </b:Interaction.Behaviors>
                        <Zoombox.ViewStack>
                            <ZoomboxView>Fit</ZoomboxView>
                        </Zoombox.ViewStack>
                        <b:Interaction.Triggers>
                            <MouseTrigger
                                ClickCount="3"
                                Mode="Right"
                                MouseButton="Left"
                                UseHandle="False">
                                <b:InvokeCommandAction Command="{ShowZoomViewImageCommand}" CommandParameter="{Binding ImageSource}" />
                            </MouseTrigger>
                            <MouseTrigger
                                ClickCount="3"
                                Mode="Left"
                                MouseButton="Left"
                                UseHandle="False">
                                <b:InvokeCommandAction Command="{ShowZoomViewImageCommand}" CommandParameter="{Binding ImageSource}" />

                            </MouseTrigger>
                            <b:EventTrigger EventName="MouseDoubleClick">
                                <CallMethodActionEx MethodName="FitToBounds" TargetObject="{Binding ElementName=zoomview1}" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>

                        <PreviewShapeBox
                            x:Name="imageBox"
                            MinWidth="100"
                            MinHeight="100"
                            MouseOverStroke="{Binding Source={x:Static MouseOverShapeViewSetting.Instance}, Path=Stroke}"
                            MouseOverStrokeThickness="{Binding Source={x:Static MouseOverShapeViewSetting.Instance}, Path=StrokeThickness}"
                            PreviewStroke="{Binding Source={x:Static PreviewShapeViewSetting.Instance}, Path=Stroke}"
                            Scale="{Binding ElementName=zoomview1, Path=Scale}"
                            SelectStrokeThickness="{Binding Source={x:Static SelectShapeViewSetting.Instance}, Path=StrokeThickness}"
                            StateStroke="{Binding Source={x:Static StateShapeViewSetting.Instance}, Path=Stroke}"
                            StateStrokeThickness="{Binding Source={x:Static StateShapeViewSetting.Instance}, Path=StrokeThickness}"
                            Stroke="{Binding Source={x:Static ShapeViewSetting.Instance}, Path=Stroke}"
                            StrokeThickness="{Binding Source={x:Static ShapeViewSetting.Instance}, Path=StrokeThickness}"
                            ViewState="{Binding ViewState}">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="SourceUpdated">
                                    <b:InvokeCommandAction Command="{Binding ImageSourceUpdatedCommand}" CommandParameter="{Binding ElementName=zoomview1}" />
                                    <CallMethodActionEx MethodName="FitToBounds" TargetObject="{Binding ElementName=zoomview1}" />
                                </b:EventTrigger>
                                <b:EventTrigger EventName="TargetUpdated">
                                    <b:InvokeCommandAction Command="{Binding ImageSourceUpdatedCommand}" CommandParameter="{Binding ElementName=zoomview1}" />
                                    <CallMethodActionEx MethodName="FitToBounds" TargetObject="{Binding ElementName=zoomview1}" />
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                            <PreviewShapeBox.Style>
                                <Style TargetType="PreviewShapeBox">
                                    <Setter Property="ImageSource" Value="{Binding ImageSource, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" />
                                    <!--<Style.Triggers>
                                   <DataTrigger Binding="{Binding ImageSource}"
                                                Value="{x:Null}">
                                       <Setter Property="ImageSource" Value="{Binding SelectedImageData.FilePath}" />
                                   </DataTrigger>
                               </Style.Triggers>-->
                                </Style>
                            </PreviewShapeBox.Style>
                        </PreviewShapeBox>
                    </Zoombox>

                    <!--<Border Padding="10,6"
                       VerticalAlignment="Bottom"
                       IsHitTestVisible="False">
                        <Border.Background>
                            <SolidColorBrush Opacity="0.3"
                                        Color="Black" />
                        </Border.Background>
                        <DockPanel VerticalAlignment="Center"
                              TextBlock.Foreground="LightGray">

                            <TextBlock DockPanel.Dock="Right">
                           <Run Text="{Binding FilePath, Converter={x:Static h:ConverterEx.GetImagePixelDisplay}}" />
                           <Run Text="|" />
                           <Run Text="{Binding FilePath, Converter={h:GetFilePathSizeToDisplayConverter}}" />
                           <Run Text="|" />
                           <Run Text="{Binding FilePath, Converter={x:Static h:Converter.GetFileLastAccessTime}}" />
                            </TextBlock>
                            <TextBlock Text="{Binding FilePath, Converter={x:Static h:Converter.GetFileName}}"
                                  TextTrimming="CharacterEllipsis"
                                  ToolTip="{Binding SrcImageNodeData.SrcFilePath}" />
                        </DockPanel>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SrcImageNodeData.SrcFilePath}"
                                            Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SrcImageNodeData}"
                                            Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>-->

                    <ListBox
                        Margin="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cattach.GuideAssemblyVersion="3.0.0.0"
                        Cattach.GuideData="1. 颜色吸管：支持拾取像素颜色用于后续规则或阈值设定。  2. 长度卡尺工具：辅助标定与尺寸估算。  3. 图像源比例尺绘制：支持实际尺寸视觉标注展示。"
                        Cattach.GuideTitle="制与辅助工具"
                        Cattach.UseGuide="True"
                        ItemsSource="{Binding ViewStates}"
                        SelectedItem="{Binding ViewState}">
                        <ItemsControl.Background>
                            <SolidColorBrush Opacity="0.5" Color="{DynamicResource {x:Static ColorKeys.Background}}" />
                        </ItemsControl.Background>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <FontIconTextBlock
                                    Margin="5,0"
                                    Text="{Binding Icon}"
                                    ToolTip="{Binding Name}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="MouseDoubleClick">
                                <b:InvokeCommandAction Command="{Binding ViewState.EditCommand}" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ListBox>
                </Grid>
            </GroupBox>
        </DockPanel>
    </DataTemplate>
</ResourceDictionary>