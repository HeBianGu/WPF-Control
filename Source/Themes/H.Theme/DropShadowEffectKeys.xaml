<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lc="clr-namespace:H.Themes.Colors"
    xmlns:local="clr-namespace:H.Themes"
    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <DropShadowEffect
        x:Key="{ComponentResourceKey ResourceId=S.DropShadowEffect.Window,
                                     TypeInTargetAssembly={x:Type local:DropShadowEffectKeys}}"
        po:Freeze="True"
        BlurRadius="20"
        Direction="270"
        Opacity="0.8"
        RenderingBias="Performance"
        ShadowDepth="0"
        Color="{DynamicResource {x:Static local:ColorKeys.DropShadowEffect}}" />

    <DropShadowEffect
        x:Key="{ComponentResourceKey ResourceId=S.DropShadowEffect.1,
                                     TypeInTargetAssembly={x:Type local:DropShadowEffectKeys}}"
        po:Freeze="True"
        BlurRadius="5"
        Direction="270"
        Opacity=".42"
        RenderingBias="Performance"
        ShadowDepth="1"
        Color="{DynamicResource {x:Static local:ColorKeys.DropShadowEffect}}" />
    <DropShadowEffect
        x:Key="{ComponentResourceKey ResourceId=S.DropShadowEffect.2,
                                     TypeInTargetAssembly={x:Type local:DropShadowEffectKeys}}"
        po:Freeze="True"
        BlurRadius="8"
        Direction="270"
        Opacity=".42"
        RenderingBias="Performance"
        ShadowDepth="1.5"
        Color="{DynamicResource {x:Static local:ColorKeys.DropShadowEffect}}" />
    <DropShadowEffect
        x:Key="{ComponentResourceKey ResourceId=S.DropShadowEffect.3,
                                     TypeInTargetAssembly={x:Type local:DropShadowEffectKeys}}"
        po:Freeze="True"
        BlurRadius="14"
        Direction="270"
        Opacity=".42"
        RenderingBias="Performance"
        ShadowDepth="4.5"
        Color="{DynamicResource {x:Static local:ColorKeys.DropShadowEffect}}" />
    <DropShadowEffect
        x:Key="{ComponentResourceKey ResourceId=S.DropShadowEffect.4,
                                     TypeInTargetAssembly={x:Type local:DropShadowEffectKeys}}"
        po:Freeze="True"
        BlurRadius="25"
        Direction="270"
        Opacity=".42"
        RenderingBias="Performance"
        ShadowDepth="8"
        Color="{DynamicResource {x:Static local:ColorKeys.DropShadowEffect}}" />
    <DropShadowEffect
        x:Key="{ComponentResourceKey ResourceId=S.DropShadowEffect.5,
                                     TypeInTargetAssembly={x:Type local:DropShadowEffectKeys}}"
        po:Freeze="True"
        BlurRadius="35"
        Direction="270"
        Opacity=".42"
        RenderingBias="Performance"
        ShadowDepth="13"
        Color="{DynamicResource {x:Static local:ColorKeys.DropShadowEffect}}" />
</ResourceDictionary>