<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="clr-namespace:H.Themes.Colors"
                    xmlns:p="clr-namespace:H.Themes.Properties"
                    xmlns:local="clr-namespace:H.Themes">
    <DataTemplate DataType="{x:Type c:ColorThemeType}">
        <TextBlock x:Name="tb_name"/>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding}"
                         Value="Default">
                <Setter TargetName="tb_name" Property="Text" Value="{x:Static p:Resources.Enum_ColorThemeType_Default}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}"
                         Value="Dark">
                <Setter TargetName="tb_name" Property="Text" Value="{x:Static p:Resources.Enum_ColorThemeType_Dark}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding}"
                         Value="Light">
                <Setter TargetName="tb_name" Property="Text" Value="{x:Static p:Resources.Enum_ColorThemeType_Light}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
</ResourceDictionary>